+TArray<FString> UBlueprintTools::ListFunctions(UBlueprint* Blueprint)
+{
+	EnsureBlueprint(Blueprint);
+	TArray<FString> Result;
+	if (!Blueprint)
+	{
+		return Result;
+	}
+
+	for (UEdGraph* Graph : Blueprint->FunctionGraphs)
+	{
+		if (Graph)
+		{
+			Result.AddUnique(Graph->GetName());
+		}
+	}
+	if (UClass* Parent = Blueprint->ParentClass)
+	{
+		for (TFieldIterator<UFunction> It(Parent, EFieldIteratorFlags::IncludeSuper); It; ++It)
+		{
+			if (UFunction* Function = *It; Function && Function->HasAnyFunctionFlags(FUNC_BlueprintCallable | FUNC_BlueprintEvent))
+			{
+				Result.AddUnique(Function->GetName());
+			}
+		}
+	}
+	Result.Sort();
+	return Result;
+}
