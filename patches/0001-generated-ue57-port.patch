+int32 UBlueprintTools::GetVariableReplication(UBlueprint* Blueprint, const FString& VariableName)
+{
+	FBPVariableDescription* Variable = FindVariable(Blueprint, VariableName);
+	if (!Variable)
+	{
+		RaiseError(FString::Printf(TEXT("Variable \"%s\" was not found."), *VariableName));
+		return 0;
+	}
+
+	if (!Variable->RepNotifyFunc.IsNone())
+	{
+		return 2;
+	}
+	return (Variable->PropertyFlags & CPF_Net) ? 1 : 0;
+}
+
+void UBlueprintTools::SetVariableReplication(UBlueprint* Blueprint, const FString& VariableName, int32 Replication)
+{
+	FBPVariableDescription* Variable = FindVariable(Blueprint, VariableName);
+	if (!Variable)
+	{
+		RaiseError(FString::Printf(TEXT("Variable \"%s\" was not found."), *VariableName));
+		return;
+	}
+
+	if (Replication <= 0)
+	{
+		Variable->PropertyFlags &= ~CPF_Net;
+		Variable->RepNotifyFunc = NAME_None;
+	}
+	else
+	{
+		Variable->PropertyFlags |= CPF_Net;
+		Variable->RepNotifyFunc = Replication == 2 ? FName(*FString::Printf(TEXT("OnRep_%s"), *VariableName)) : NAME_None;
+		if (Replication == 2 && Blueprint)
+		{
+			AddFunctionGraph(Blueprint, Variable->RepNotifyFunc.ToString());
+		}
+	}
+
+	if (Blueprint)
+	{
+		FBlueprintEditorUtils::MarkBlueprintAsStructurallyModified(Blueprint);
+	}
+}
+
+TArray<FString> UBlueprintTools::FindNodeTypes(UEdGraph* Graph, const FString& TypeIdFilter)
+{
+	TArray<FString> Result;
+	if (UMcpBlueprintGraphEditorBridge* Editor = GetGraphEditor(Graph))
+	{
+		Editor->ListAvailableNodes(Result, {});
+	}
+
+	if (!TypeIdFilter.IsEmpty())
+	{
+		Result = Result.FilterByPredicate([&TypeIdFilter](const FString& Value)
+		{
+			return Value.Contains(TypeIdFilter, ESearchCase::IgnoreCase);
+		});
+	}
+	Result.Sort();
+	return Result;
+}
+
+TArray<FString> UBlueprintTools::FindNodeCategories(UEdGraph* Graph, const FString& CategoryFilter)
+{
+	TSet<FString> Categories;
+	for (const FString& TypeId : FindNodeTypes(Graph))
+	{
+		FString Category;
+		FString Name;
+		if (TypeId.Split(TEXT("|"), &Category, &Name, ESearchCase::CaseSensitive, ESearchDir::FromEnd))
+		{
+			if (CategoryFilter.IsEmpty() || Category.Contains(CategoryFilter, ESearchCase::IgnoreCase))
+			{
+				Categories.Add(Category);
+			}
+		}
+	}
+
+	TArray<FString> Result = Categories.Array();
+	Result.Sort();
+	return Result;
+}
+
+UEdGraphNode* UBlueprintTools::CreateNode(UEdGraph* Graph, const FString& TypeId, FIntPoint Position)
+{
+	if (UMcpBlueprintGraphEditorBridge* Editor = GetGraphEditor(Graph))
+	{
+		UEdGraphNode* Node = Editor->CreateNodeFromName(TypeId, FVector2D(Position.X, Position.Y), {});
+		if (!Node)
+		{
+			RaiseError(FString::Printf(TEXT("Node type \"%s\" was not created."), *TypeId));
+		}
+		return Node;
+	}
+	return nullptr;
+}
+
+void UBlueprintTools::DeleteNode(UEdGraphNode* Node)
+{
+	UEdGraph* Graph = GetNodeGraph(Node);
+	if (!Graph)
+	{
+		return;
+	}
+
+	if (UMcpBlueprintGraphEditorBridge* Editor = GetGraphEditor(Graph))
+	{
+		TArray<UK2Node*> Nodes;
+		if (UK2Node* K2Node = Cast<UK2Node>(Node))
+		{
+			Nodes.Add(K2Node);
+		}
+		Editor->RemoveNodes(Nodes);
+	}
+}
+
+TArray<FEditorToolsetBlueprintNodeInfo> UBlueprintTools::FindNodes(UEdGraph* Graph, const FString& TitleFilter)
+{
+	TArray<FEditorToolsetBlueprintNodeInfo> Result;
+	if (!Graph)
+	{
+		RaiseError(TEXT("Graph is null."));
+		return Result;
+	}
+
+	for (UEdGraphNode* Node : Graph->Nodes)
+	{
+		if (!Node)
+		{
+			continue;
+		}
+
+		const FString Title = Node->GetNodeTitle(ENodeTitleType::ListView).ToString();
+		if (!TitleFilter.IsEmpty() && !Title.Contains(TitleFilter, ESearchCase::IgnoreCase))
+		{
+			continue;
+		}
+		Result.Add(MakeNodeInfo(Node));
+	}
+	return Result;
+}
