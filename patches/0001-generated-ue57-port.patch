+UMaterial* UMaterialTools::CreateMaterial(const FString& FolderPath, const FString& AssetName)
+{
+	UMaterialFactoryNew* Factory = NewObject<UMaterialFactoryNew>();
+	UObject* Asset = FAssetToolsModule::GetModule().Get().CreateAsset(AssetName, FolderPath, UMaterial::StaticClass(), Factory);
+	UMaterial* Material = Cast<UMaterial>(Asset);
+	if (!Material)
+	{
+		RaiseError(FString::Printf(TEXT("Unable to create Material in %s/%s."), *FolderPath, *AssetName));
+	}
+	return Material;
+}
+
+UMaterialFunction* UMaterialTools::CreateFunction(const FString& FolderPath, const FString& AssetName)
+{
+	UMaterialFunctionFactoryNew* Factory = NewObject<UMaterialFunctionFactoryNew>();
+	UObject* Asset = FAssetToolsModule::GetModule().Get().CreateAsset(AssetName, FolderPath, UMaterialFunction::StaticClass(), Factory);
+	UMaterialFunction* Function = Cast<UMaterialFunction>(Asset);
+	if (!Function)
+	{
+		RaiseError(FString::Printf(TEXT("Unable to create MaterialFunction in %s/%s."), *FolderPath, *AssetName));
+	}
+	return Function;
+}
+
+UMaterialParameterCollection* UMaterialTools::CreateParameterCollection(const FString& FolderPath, const FString& AssetName)
+{
+	UMaterialParameterCollectionFactoryNew* Factory = NewObject<UMaterialParameterCollectionFactoryNew>();
+	UObject* Asset = FAssetToolsModule::GetModule().Get().CreateAsset(AssetName, FolderPath, UMaterialParameterCollection::StaticClass(), Factory);
+	UMaterialParameterCollection* Collection = Cast<UMaterialParameterCollection>(Asset);
+	if (!Collection)
+	{
+		RaiseError(FString::Printf(TEXT("Unable to create MaterialParameterCollection in %s/%s."), *FolderPath, *AssetName));
+	}
+	return Collection;
+}
+
+TArray<FSoftClassPath> UMaterialTools::ListExpressionClasses(UObject* MaterialOrFunction, const FString& Search)
+{
+	if (!AsMaterial(MaterialOrFunction) && !AsFunction(MaterialOrFunction))
+	{
+		RaiseError(TEXT("Expected a Material or MaterialFunction."));
+		return {};
+	}
+
+	const bool bForMaterial = AsMaterial(MaterialOrFunction) != nullptr;
+	TArray<FSoftClassPath> Result;
+	for (TObjectIterator<UClass> It; It; ++It)
+	{
+		UClass* Class = *It;
+		if (!Class->IsChildOf(UMaterialExpression::StaticClass()) || Class->HasAnyClassFlags(CLASS_Abstract | CLASS_Deprecated | CLASS_NewerVersionExists))
+		{
+			continue;
+		}
+
+		if (bForMaterial && IsFunctionOnlyExpression(Class))
+		{
+			continue;
+		}
+
+		const FString Path = Class->GetPathName();
+		if (!Search.IsEmpty() && !Path.Contains(Search, ESearchCase::IgnoreCase))
+		{
+			continue;
+		}
+
+		Result.Add(FSoftClassPath(Path));
+	}
+
+	Result.Sort([](const FSoftClassPath& A, const FSoftClassPath& B)
+	{
+		return A.ToString() < B.ToString();
+	});
+	return Result;
+}
+
+UMaterialExpression* UMaterialTools::AddExpression(
+	UObject* MaterialOrFunction,
+	TSubclassOf<UMaterialExpression> ExpressionClass,
+	int32 X,
+	int32 Y)
+{
+	if (!ExpressionClass)
+	{
+		RaiseError(TEXT("ExpressionClass is null."));
+		return nullptr;
+	}
+
+	UMaterialExpression* Expression = nullptr;
+	if (UMaterial* Material = AsMaterial(MaterialOrFunction))
+	{
+		if (IsFunctionOnlyExpression(ExpressionClass))
+		{
+			RaiseError(TEXT("Function input/output expressions can only be added to a MaterialFunction."));
+			return nullptr;
+		}
+		Expression = UMaterialEditingLibrary::CreateMaterialExpression(Material, ExpressionClass, X, Y);
+	}
+	else if (UMaterialFunction* Function = AsFunction(MaterialOrFunction))
+	{
+		Expression = UMaterialEditingLibrary::CreateMaterialExpressionInFunction(Function, ExpressionClass, X, Y);
+	}
+	else
+	{
+		RaiseError(TEXT("Expected a Material or MaterialFunction."));
+	}
+
+	if (!Expression)
+	{
+		RaiseError(TEXT("Failed to create material expression."));
+	}
+	Refresh(MaterialOrFunction);
+	return Expression;
+}
+
+void UMaterialTools::DeleteExpression(UObject* MaterialOrFunction, UMaterialExpression* Expression)
+{
+	if (!Expression)
+	{
+		RaiseError(TEXT("Expression is null."));
+		return;
+	}
+
+	if (UMaterial* Material = AsMaterial(MaterialOrFunction))
+	{
+		UMaterialEditingLibrary::DeleteMaterialExpression(Material, Expression);
+	}
+	else if (UMaterialFunction* Function = AsFunction(MaterialOrFunction))
+	{
+		UMaterialEditingLibrary::DeleteMaterialExpressionInFunction(Function, Expression);
+	}
+	else
+	{
+		RaiseError(TEXT("Expected a Material or MaterialFunction."));
+		return;
+	}
+
+	Refresh(MaterialOrFunction);
+}
+
+TArray<UMaterialExpression*> UMaterialTools::GetExpressions(UObject* MaterialOrFunction)
+{
+	if (UMaterial* Material = AsMaterial(MaterialOrFunction))
+	{
+		return Material->GetExpressionCollection().Expressions;
+	}
+	if (UMaterialFunction* Function = AsFunction(MaterialOrFunction))
+	{
+		return Function->GetExpressionCollection().Expressions;
+	}
+
+	RaiseError(TEXT("Expected a Material or MaterialFunction."));
+	return {};
+}
+
+void UMaterialTools::LayoutExpressions(UObject* MaterialOrFunction)
+{
+	if (UMaterial* Material = AsMaterial(MaterialOrFunction))
+	{
+		UMaterialEditingLibrary::LayoutMaterialExpressions(Material);
+	}
+	else if (UMaterialFunction* Function = AsFunction(MaterialOrFunction))
+	{
+		UMaterialEditingLibrary::LayoutMaterialFunctionExpressions(Function);
+	}
+	else
+	{
+		RaiseError(TEXT("Expected a Material or MaterialFunction."));
+		return;
+	}
+
+	Refresh(MaterialOrFunction);
+}
+
+TArray<FString> UMaterialTools::ListParameterGroups(UObject* MaterialOrFunction)
+{
+	TSet<FString> Groups;
+	for (UMaterialExpression* Expression : GetExpressions(MaterialOrFunction))
+	{
+		if (const UMaterialExpressionParameter* Parameter = Cast<UMaterialExpressionParameter>(Expression))
+		{
+			if (!Parameter->Group.IsNone())
+			{
+				Groups.Add(Parameter->Group.ToString());
+			}
+		}
+	}
+
+	TArray<FString> Result = Groups.Array();
+	Result.Sort();
+	return Result;
+}
+
+void UMaterialTools::RenameParameterGroup(UObject* MaterialOrFunction, const FString& OldName, const FString& NewName)
+{
+	const FName OldGroup(*OldName);
+	const FName NewGroup(*NewName);
+	bool bRenamed = false;
+	if (UMaterial* Material = AsMaterial(MaterialOrFunction))
+	{
+		bRenamed = UMaterialEditingLibrary::RenameMaterialParameterGroup(Material, OldGroup, NewGroup);
+	}
+	else if (UMaterialFunction* Function = AsFunction(MaterialOrFunction))
+	{
+		bRenamed = UMaterialEditingLibrary::RenameMaterialFunctionParameterGroup(Function, OldGroup, NewGroup);
+	}
+	else
+	{
+		RaiseError(TEXT("Expected a Material or MaterialFunction."));
+		return;
+	}
+
+	if (!bRenamed)
+	{
+		RaiseError(FString::Printf(TEXT("Parameter group \"%s\" not found."), *OldName));
+		return;
+	}
+	Refresh(MaterialOrFunction);
+}
+
+void UMaterialTools::DeleteParameterGroup(UObject* MaterialOrFunction, const FString& GroupName)
+{
+	RenameParameterGroup(MaterialOrFunction, GroupName, TEXT("None"));
+}
+
+TArray<FString> UMaterialTools::GetExpressionInputNames(UMaterialExpression* Expression)
+{
+	if (!Expression)
+	{
+		RaiseError(TEXT("Expression is null."));
+		return {};
+	}
+	return UMaterialEditingLibrary::GetMaterialExpressionInputNames(Expression);
+}
+
+TArray<FString> UMaterialTools::GetExpressionOutputNames(UMaterialExpression* Expression)
+{
+	TArray<FString> Result;
+	if (!Expression)
+	{
+		RaiseError(TEXT("Expression is null."));
+		return Result;
+	}
+
+	for (const FExpressionOutput& Output : Expression->GetOutputs())
+	{
+		Result.Add(Output.OutputName.ToString());
+	}
+	return Result;
+}
+
+void UMaterialTools::ConnectExpressions(
+	UMaterialExpression* FromExpression,
+	const FString& FromOutputName,
+	UMaterialExpression* ToExpression,
+	const FString& ToInputName)
+{
+	if (!UMaterialEditingLibrary::ConnectMaterialExpressions(FromExpression, FromOutputName, ToExpression, ToInputName))
+	{
+		RaiseError(TEXT("Failed to connect material expressions."));
+		return;
+	}
+	Refresh(ToExpression ? ToExpression->GetOuter() : nullptr);
+}
+
+void UMaterialTools::DisconnectExpressions(UMaterialExpression* ToExpression, const FString& ToInputName)
+{
+	if (!ToExpression)
+	{
+		RaiseError(TEXT("Expression is null."));
+		return;
+	}
+
+	bool bDisconnected = false;
+	for (FExpressionInput* Input : ToExpression->GetInputsView())
+	{
+		if (Input && (ToInputName.IsEmpty() || Input->InputName.ToString() == ToInputName))
+		{
+			if (Input->Expression)
+			{
+				Input->Expression = nullptr;
+				bDisconnected = true;
+			}
+			if (!ToInputName.IsEmpty())
+			{
+				break;
+			}
+		}
+	}
+
+	if (!bDisconnected)
+	{
+		RaiseError(FString::Printf(TEXT("Failed to disconnect input \"%s\"."), *ToInputName));
+		return;
+	}
+
+	ToExpression->Modify();
+	ToExpression->MarkPackageDirty();
+	Refresh(ToExpression->GetOuter());
+}
+
+TArray<FEditorToolsetMaterialInputSource> UMaterialTools::GetExpressionInputs(UObject* MaterialOrFunction, UMaterialExpression* Expression)
+{
+	TArray<FEditorToolsetMaterialInputSource> Result;
+	if (!Expression)
+	{
+		RaiseError(TEXT("Expression is null."));
+		return Result;
+	}
+
+	TArray<FString> InputNames = UMaterialEditingLibrary::GetMaterialExpressionInputNames(Expression);
+	int32 Index = 0;
+	for (const FExpressionInput* Input : Expression->GetInputsView())
+	{
+		FEditorToolsetMaterialInputSource Source;
+		Source.InputName = InputNames.IsValidIndex(Index) ? InputNames[Index] : Input->InputName.ToString();
+		Source.Expression = Input ? Input->Expression : nullptr;
+		Source.OutputName = Source.Expression ? GetExpressionOutputName(Source.Expression, Input->OutputIndex) : TEXT("");
+		Result.Add(Source);
+		++Index;
+	}
+	return Result;
+}
+
+FEditorToolsetMaterialInputSource UMaterialTools::GetPropertyInput(UMaterial* Material, EMaterialProperty MaterialProperty)
+{
+	FEditorToolsetMaterialInputSource Result;
+	if (!Material)
+	{
+		RaiseError(TEXT("Material is null."));
+		return Result;
+	}
+
+	Result.Expression = UMaterialEditingLibrary::GetMaterialPropertyInputNode(Material, MaterialProperty);
+	Result.OutputName = Result.Expression ? UMaterialEditingLibrary::GetMaterialPropertyInputNodeOutputName(Material, MaterialProperty) : TEXT("");
+	return Result;
+}
+
+void UMaterialTools::ConnectToOutput(UMaterialExpression* Expression, const FString& OutputName, EMaterialProperty MaterialProperty)
+{
+	if (!UMaterialEditingLibrary::ConnectMaterialProperty(Expression, OutputName, MaterialProperty))
+	{
+		RaiseError(TEXT("Failed to connect expression to material output."));
+		return;
+	}
+	Refresh(Expression ? Expression->GetOuter() : nullptr);
+}
+
+void UMaterialTools::DisconnectFromOutput(UMaterial* Material, EMaterialProperty MaterialProperty)
+{
+	if (!Material)
+	{
+		RaiseError(TEXT("Material is null."));
+		return;
+	}
+
+	FExpressionInput* Input = Material->GetExpressionInputForProperty(MaterialProperty);
+	if (!Input || !Input->Expression)
+	{
+		RaiseError(TEXT("Material property is already disconnected or unavailable."));
+		return;
+	}
+
+	Input->Expression = nullptr;
+	Material->Modify();
+	Material->MarkPackageDirty();
+	Refresh(Material);
+}
+
+void UMaterialTools::DeleteUnusedExpressions(UMaterial* Material)
+{
+	if (!Material)
+	{
+		RaiseError(TEXT("Material is null."));
+		return;
+	}
+
+	TArray<UMaterialExpression*> AllExpressions = Material->GetExpressionCollection().Expressions;
+	TSet<UMaterialExpression*> UsedExpressions;
+	TArray<UMaterialExpression*> Frontier;
+
+	auto VisitInput = [&UsedExpressions, &Frontier](FExpressionInput* Input)
+	{
+		if (Input && Input->Expression && !UsedExpressions.Contains(Input->Expression))
+		{
+			UsedExpressions.Add(Input->Expression);
+			Frontier.Add(Input->Expression);
+		}
+	};
+
+	for (uint32 PropertyIndex = 0; PropertyIndex < MP_MAX; ++PropertyIndex)
+	{
+		VisitInput(Material->GetExpressionInputForProperty(static_cast<EMaterialProperty>(PropertyIndex)));
+	}
+
+	while (!Frontier.IsEmpty())
+	{
+		UMaterialExpression* Expression = Frontier.Pop(EAllowShrinking::No);
+		for (FExpressionInput* Input : Expression->GetInputsView())
+		{
+			VisitInput(Input);
+		}
+	}
+
+	for (UMaterialExpression* Expression : AllExpressions)
+	{
+		if (Expression && !UsedExpressions.Contains(Expression))
+		{
+			UMaterialEditingLibrary::DeleteMaterialExpression(Material, Expression);
+		}
+	}
+	Refresh(Material);
+}
+
+void UMaterialTools::Recompile(UObject* MaterialOrFunction)
+{
+	if (UMaterial* Material = AsMaterial(MaterialOrFunction))
+	{
+		UMaterialEditingLibrary::RecompileMaterial(Material);
+	}
+	else if (UMaterialFunction* Function = AsFunction(MaterialOrFunction))
+	{
+		UMaterialEditingLibrary::UpdateMaterialFunction(Function);
+	}
+	else
+	{
+		RaiseError(TEXT("Expected a Material or MaterialFunction."));
+	}
+}
+
+TArray<FAssetData> UMaterialTools::GetReferencingMaterials(UMaterialFunction* MaterialFunction)
+{
+	TArray<FAssetData> Result;
+	if (!MaterialFunction)
+	{
+		RaiseError(TEXT("MaterialFunction is null."));
+		return Result;
+	}
+
+	FAssetRegistryModule& AssetRegistryModule = FModuleManager::LoadModuleChecked<FAssetRegistryModule>("AssetRegistry");
+	IAssetRegistry& AssetRegistry = AssetRegistryModule.Get();
+
+	TArray<FName> Referencers;
+	AssetRegistry.GetReferencers(MaterialFunction->GetOutermost()->GetFName(), Referencers, UE::AssetRegistry::EDependencyCategory::All);
+	for (const FName Referencer : Referencers)
+	{
+		TArray<FAssetData> Assets;
+		AssetRegistry.GetAssetsByPackageName(Referencer, Assets);
+		for (const FAssetData& AssetData : Assets)
+		{
+			if (AssetData.AssetClassPath.GetAssetName() == UMaterial::StaticClass()->GetFName())
+			{
+				Result.Add(AssetData);
+			}
+		}
+	}
+	return Result;
+}
+
+UMaterial* UMaterialTools::AsMaterial(UObject* Object)
+{
+	return Cast<UMaterial>(Object);
+}
+
+UMaterialFunction* UMaterialTools::AsFunction(UObject* Object)
+{
+	return Cast<UMaterialFunction>(Object);
+}
+
+bool UMaterialTools::IsFunctionOnlyExpression(UClass* ExpressionClass)
+{
+	return ExpressionClass &&
+		(ExpressionClass->IsChildOf(UMaterialExpressionFunctionInput::StaticClass()) ||
+		 ExpressionClass->IsChildOf(UMaterialExpressionFunctionOutput::StaticClass()));
+}
+
+FString UMaterialTools::GetExpressionOutputName(const UMaterialExpression* Expression, int32 OutputIndex)
+{
+	if (!Expression)
+	{
+		return TEXT("");
+	}
+
+	const TArray<FExpressionOutput>& Outputs = const_cast<UMaterialExpression*>(Expression)->GetOutputs();
+	if (!Outputs.IsValidIndex(OutputIndex))
+	{
+		return TEXT("");
+	}
+	return Outputs[OutputIndex].OutputName.ToString();
+}
+
+void UMaterialTools::Refresh(UObject* MaterialOrFunction)
+{
+	if (UMaterial* Material = AsMaterial(MaterialOrFunction))
+	{
+		UMaterialEditingLibrary::RecompileMaterial(Material);
+		Material->MarkPackageDirty();
+	}
+	else if (UMaterialFunction* Function = AsFunction(MaterialOrFunction))
+	{
+		UMaterialEditingLibrary::UpdateMaterialFunction(Function);
+		Function->MarkPackageDirty();
+	}
+}
+
+void UMaterialTools::RaiseError(const FString& Message)
+{
+	FFrame::KismetExecutionMessage(*Message, ELogVerbosity::Error);
+}
