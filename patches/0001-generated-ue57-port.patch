 // Copyright Epic Games, Inc. All Rights Reserved.
 
 #include "Modules/ModuleManager.h"
+#include "Misc/CoreDelegates.h"
+#include "IPythonScriptPlugin.h"
+#include "ToolsetRegistry/ToolsetRegistrySubsystem.h"
 #include "ToolsetRegistry/UToolsetRegistry.h"
 
+#include "BlueprintTools.h"
+#include "CurveTableTools.h"
 #include "EditorAppToolset.h"
 #include "LogsToolset.h"
+#include "MaterialInstanceTools.h"
+#include "MaterialTools.h"
 
 #define LOCTEXT_NAMESPACE "FEditorToolsetModule"
 
 class FEditorToolsetModule : public IModuleInterface
 {
+public:
 	void StartupModule()
 	{
 		UToolsetRegistry::RegisterToolsetClass(UEditorAppToolset::StaticClass());
 		UToolsetRegistry::RegisterToolsetClass(ULogsToolset::StaticClass());
+		UToolsetRegistry::RegisterToolsetClass(UBlueprintTools::StaticClass());
+		UToolsetRegistry::RegisterToolsetClass(UCurveTableTools::StaticClass());
+		UToolsetRegistry::RegisterToolsetClass(UMaterialInstanceTools::StaticClass());
+		UToolsetRegistry::RegisterToolsetClass(UMaterialTools::StaticClass());
+
+		EnginePreExitHandle = FCoreDelegates::OnEnginePreExit.AddRaw(
+			this, &FEditorToolsetModule::HandleEnginePreExit);
 	}
 
 	void ShutdownModule()
 	{
+		if (EnginePreExitHandle.IsValid())
+		{
+			FCoreDelegates::OnEnginePreExit.Remove(EnginePreExitHandle);
+			EnginePreExitHandle.Reset();
+		}
+
+		HandleEnginePreExit();
+
+		UToolsetRegistry::UnregisterToolsetClass(UMaterialTools::StaticClass());
+		UToolsetRegistry::UnregisterToolsetClass(UMaterialInstanceTools::StaticClass());
+		UToolsetRegistry::UnregisterToolsetClass(UCurveTableTools::StaticClass());
+		UToolsetRegistry::UnregisterToolsetClass(UBlueprintTools::StaticClass());
 		UToolsetRegistry::UnregisterToolsetClass(ULogsToolset::StaticClass());
 		UToolsetRegistry::UnregisterToolsetClass(UEditorAppToolset::StaticClass());
 	}
+
+private:
+	void HandleEnginePreExit()
+	{
+		if (bHandledEnginePreExit)
+		{
+			return;
+		}
+
+		bHandledEnginePreExit = true;
+		ResetRegistryForShutdown();
+		CleanupEditorToolsetPythonPackage();
+	}
+
+	static void ResetRegistryForShutdown()
+	{
+		if (auto ToolsetRegistrySubsystem = UToolsetRegistrySubsystem::Get();
+			ToolsetRegistrySubsystem.HasValue())
+		{
+			ToolsetRegistrySubsystem.GetValue()->ToolsetRegistry.ResetForShutdown();
+		}
+	}
+
+	static void CleanupEditorToolsetPythonPackage()
+	{
+		IPythonScriptPlugin* PythonScriptPlugin = IPythonScriptPlugin::Get();
+		if (!PythonScriptPlugin || !PythonScriptPlugin->IsPythonInitialized())
+		{
+			return;
+		}
+
+		static constexpr const TCHAR* CleanupCommand =
+			TEXT("import importlib\n")
+			TEXT("module = importlib.import_module('editor_toolset.shutdown')\n")
+			TEXT("module.cleanup()\n");
+		PythonScriptPlugin->ExecPythonCommand(CleanupCommand);
+	}
+
+	FDelegateHandle EnginePreExitHandle;
+	bool bHandledEnginePreExit = false;
 };
 
 #undef LOCTEXT_NAMESPACE
