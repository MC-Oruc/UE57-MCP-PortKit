+FString UBlueprintTools::GetCreateEventFunction(UK2Node_CreateDelegate* Node)
+{
+	if (!Node)
+	{
+		RaiseError(TEXT("Create Event node is null."));
+		return {};
+	}
+
+	const FName FunctionName = Node->GetFunctionName();
+	return FunctionName == NAME_None ? FString() : FunctionName.ToString();
+}
+
+void UBlueprintTools::SetCreateEventFunction(UK2Node_CreateDelegate* Node, const FString& FunctionName)
+{
+	if (!Node)
+	{
+		RaiseError(TEXT("Create Event node is null."));
+		return;
+	}
+
+	const TArray<FString> CompatibleFunctions = ListCompatibleEventFunctions(Node);
+	if (!CompatibleFunctions.Contains(FunctionName))
+	{
+		RaiseError(FString::Printf(TEXT("\"%s\" is not compatible with this Create Event node."), *FunctionName));
+		return;
+	}
+
+	Node->Modify();
+	Node->SetFunction(FName(*FunctionName));
+	Node->HandleAnyChange(true);
+	if (UBlueprint* Blueprint = Node->GetBlueprint())
+	{
+		FBlueprintEditorUtils::MarkBlueprintAsModified(Blueprint);
+	}
+
+	if (Node->GetFunctionName() == NAME_None)
+	{
+		RaiseError(FString::Printf(TEXT("Failed to bind \"%s\" to the Create Event node."), *FunctionName));
+	}
+}
+
+TArray<FString> UBlueprintTools::ListCompatibleEventFunctions(UK2Node_CreateDelegate* Node)
+{
+	TArray<FString> Result;
+	if (!Node)
+	{
+		RaiseError(TEXT("Create Event node is null."));
+		return Result;
+	}
+
+	UFunction* DelegateSignature = Node->GetDelegateSignature();
+	UClass* ScopeClass = Node->GetScopeClass();
+	if (!DelegateSignature || !ScopeClass)
+	{
+		RaiseError(TEXT("Create Event node has no connected delegate signature or scope class."));
+		return Result;
+	}
+
+	for (TFieldIterator<UFunction> It(ScopeClass); It; ++It)
+	{
+		UFunction* Function = *It;
+		if (Function &&
+			DelegateSignature->IsSignatureCompatibleWith(Function) &&
+			UEdGraphSchema_K2::FunctionCanBeUsedInDelegate(Function))
+		{
+			Result.AddUnique(Function->GetName());
+		}
+	}
+	Result.Sort();
+	return Result;
+}
+
+TArray<FEditorToolsetBlueprintNodeInfo> UBlueprintTools::GetConnectedSubgraph(UEdGraphNode* Node)
+{
+	TArray<FEditorToolsetBlueprintNodeInfo> Result;
+	if (!Node)
+	{
+		RaiseError(TEXT("Node is null."));
+		return Result;
+	}
+
+	TSet<UEdGraphNode*> Visited;
+	TArray<UEdGraphNode*> Queue = { Node };
+	while (!Queue.IsEmpty())
+	{
+		UEdGraphNode* Current = Queue.Pop(EAllowShrinking::No);
+		if (!Current || Visited.Contains(Current))
+		{
+			continue;
+		}
+
+		Visited.Add(Current);
+		Result.Add(MakeNodeInfo(Current));
+		for (UEdGraphPin* Pin : Current->Pins)
+		{
+			if (!Pin)
+			{
+				continue;
+			}
+			for (UEdGraphPin* LinkedPin : Pin->LinkedTo)
+			{
+				if (LinkedPin)
+				{
+					Queue.Add(LinkedPin->GetOwningNode());
+				}
+			}
+		}
+	}
+	return Result;
+}
