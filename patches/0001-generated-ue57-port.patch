+        _wire_exec(task, 'OnCompleted', end)
+        _wire_exec(task, 'OnBlendOut', end)
+        _wire_exec(task, 'OnInterrupted', end)
+        result = _run_decompiler([event, task, end])
+        self.assertEqual(result.count('('), result.count(')'))
