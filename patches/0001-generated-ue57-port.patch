+FString UBlueprintTools::GetGraphDslDocs()
+{
+	return TEXT("Native BlueprintTools graph DSL subset:\n(event Custom|EventName\n  (NodeType|Id arg...))\nArguments are assigned to data input pins in pin order. Exec pins are chained in statement order. Use FindNodeTypes and GetNodeTypePins before writing.");
