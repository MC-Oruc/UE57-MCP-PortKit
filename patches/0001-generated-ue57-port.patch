+# Copyright Epic Games, Inc. All Rights Reserved.
+
+"""Deterministic shutdown cleanup for UE 5.7 EditorToolset Python classes."""
+
+from __future__ import annotations
+
+import gc
+import sys
+
+
+_MODULE_PREFIXES = (
+    'editor_toolset.toolset_loader',
+    'editor_toolset.toolsets',
+)
+
+
+def _is_editor_toolset_object(value) -> bool:
+    module_name = getattr(value, '__module__', '')
+    return isinstance(module_name, str) and module_name.startswith('editor_toolset.toolsets')
+
+
+def _clear_module_globals(module) -> None:
+    for name, value in list(vars(module).items()):
+        if name.startswith('__'):
+            continue
+        if name in {'_registration', '_TOOLSET_CLASSES'} or _is_editor_toolset_object(value):
+            setattr(module, name, None)
+
+
+def cleanup() -> None:
+    """Release EditorToolset Python package references before Python finalizes."""
+    for module_name, module in list(sys.modules.items()):
+        if module_name == 'editor_toolset' or module_name.startswith(_MODULE_PREFIXES):
+            if module is not None:
+                _clear_module_globals(module)
+
+    parent = sys.modules.get('editor_toolset')
+    if parent is not None and hasattr(parent, 'toolsets'):
+        setattr(parent, 'toolsets', None)
+
+    for module_name in sorted(list(sys.modules.keys()), reverse=True):
+        if module_name.startswith(_MODULE_PREFIXES):
+            sys.modules.pop(module_name, None)
+
+    gc.collect()
