+    def chain_async_result(
+        self, result_future: Future[dict[str, Any]],
+        async_result: unreal.ToolCallAsyncResultString
+    ) -> unreal.ToolCallAsyncResultString:
+        """Chain the completion of a future to an async result.
+
+        Args:
