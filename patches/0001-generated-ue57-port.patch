+UBlueprint* UBlueprintTools::Create(const FString& FolderPath, const FString& AssetName, UClass* AssetType)
+{
+	if (!AssetType)
+	{
+		RaiseError(TEXT("AssetType is null."));
+		return nullptr;
+	}
+
+	UBlueprintFactory* Factory = NewObject<UBlueprintFactory>();
+	Factory->ParentClass = AssetType;
+
+	UObject* Asset = FAssetToolsModule::GetModule().Get().CreateAsset(
+		AssetName,
+		FolderPath,
+		UBlueprint::StaticClass(),
+		Factory);
+
+	UBlueprint* Blueprint = Cast<UBlueprint>(Asset);
+	if (!Blueprint)
+	{
+		RaiseError(FString::Printf(TEXT("Unable to create Blueprint in %s/%s."), *FolderPath, *AssetName));
+	}
+	return Blueprint;
+}
