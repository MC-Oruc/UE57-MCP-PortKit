+
+enum class EBlueprintDslTokenKind
+{
+	Atom,
+	String,
+	Open,
+	Close
+};
+
+struct FBlueprintDslToken
+{
+	EBlueprintDslTokenKind Kind = EBlueprintDslTokenKind::Atom;
+	FString Text;
+};
+
+bool TokenizeBlueprintDsl(const FString& Code, TArray<FBlueprintDslToken>& OutTokens, FString& OutError)
+{
+	for (int32 Index = 0; Index < Code.Len();)
+	{
+		const TCHAR Ch = Code[Index];
+		if (FChar::IsWhitespace(Ch))
+		{
+			++Index;
+			continue;
+		}
+		if (Ch == TEXT('('))
+		{
+			OutTokens.Add({ EBlueprintDslTokenKind::Open, TEXT("(") });
+			++Index;
+			continue;
+		}
+		if (Ch == TEXT(')'))
+		{
+			OutTokens.Add({ EBlueprintDslTokenKind::Close, TEXT(")") });
+			++Index;
+			continue;
+		}
+		if (Ch == TEXT('"'))
+		{
+			FString Value;
+			++Index;
+			bool bClosed = false;
+			while (Index < Code.Len())
+			{
+				const TCHAR Current = Code[Index++];
+				if (Current == TEXT('"'))
+				{
+					bClosed = true;
+					break;
+				}
+				if (Current == TEXT('\\') && Index < Code.Len())
+				{
+					const TCHAR Escaped = Code[Index++];
+					Value.AppendChar(Escaped == TEXT('n') ? TEXT('\n') : Escaped);
+					continue;
+				}
+				Value.AppendChar(Current);
+			}
+			if (!bClosed)
+			{
+				OutError = TEXT("Unterminated string literal in graph DSL.");
+				return false;
+			}
+			OutTokens.Add({ EBlueprintDslTokenKind::String, Value });
+			continue;
+		}
+
+		FString Value;
+		while (Index < Code.Len())
+		{
+			const TCHAR Current = Code[Index];
+			if (FChar::IsWhitespace(Current) || Current == TEXT('(') || Current == TEXT(')'))
+			{
+				break;
+			}
+			Value.AppendChar(Current);
+			++Index;
+		}
+		if (Value.IsEmpty())
+		{
+			OutError = FString::Printf(TEXT("Unexpected DSL character '%c'."), Ch);
+			return false;
+		}
+		OutTokens.Add({ EBlueprintDslTokenKind::Atom, Value });
+	}
+	return true;
+}
+
+bool ParseBlueprintDslList(const TArray<FBlueprintDslToken>& Tokens, int32& Index, FBlueprintDslForm& OutForm, FString& OutError)
+{
+	if (!Tokens.IsValidIndex(Index) || Tokens[Index].Kind != EBlueprintDslTokenKind::Open)
+	{
+		OutError = TEXT("Expected '(' in graph DSL.");
+		return false;
+	}
+	++Index;
+	if (!Tokens.IsValidIndex(Index) || Tokens[Index].Kind == EBlueprintDslTokenKind::Open || Tokens[Index].Kind == EBlueprintDslTokenKind::Close)
+	{
+		OutError = TEXT("Expected form head in graph DSL.");
+		return false;
+	}
+
+	OutForm.Head = Tokens[Index++].Text;
+	while (Tokens.IsValidIndex(Index) && Tokens[Index].Kind != EBlueprintDslTokenKind::Close)
+	{
+		if (Tokens[Index].Kind == EBlueprintDslTokenKind::Open)
+		{
+			FBlueprintDslForm Child;
+			if (!ParseBlueprintDslList(Tokens, Index, Child, OutError))
+			{
+				return false;
+			}
+			OutForm.Children.Add(MoveTemp(Child));
+			continue;
+		}
+
+		OutForm.Args.Add(Tokens[Index++].Text);
+	}
+
+	if (!Tokens.IsValidIndex(Index) || Tokens[Index].Kind != EBlueprintDslTokenKind::Close)
+	{
+		OutError = TEXT("Unclosed list in graph DSL.");
+		return false;
+	}
+	++Index;
+	return true;
+}
+
+bool ParseBlueprintDsl(const FString& Code, TArray<FBlueprintDslForm>& OutForms, FString& OutError)
+{
+	TArray<FBlueprintDslToken> Tokens;
+	if (!TokenizeBlueprintDsl(Code, Tokens, OutError))
+	{
+		return false;
+	}
+
+	int32 Index = 0;
+	while (Index < Tokens.Num())
+	{
+		FBlueprintDslForm Form;
+		if (!ParseBlueprintDslList(Tokens, Index, Form, OutError))
+		{
+			return false;
+		}
+		OutForms.Add(MoveTemp(Form));
+	}
+	return true;
+}
+
+bool IsExecPin(const UEdGraphPin* Pin)
+{
+	return Pin && Pin->PinType.PinCategory == UEdGraphSchema_K2::PC_Exec;
+}
+
+UEdGraphPin* FindFirstPin(UEdGraphNode* Node, EEdGraphPinDirection Direction, bool bExec)
+{
+	if (!Node)
+	{
+		return nullptr;
+	}
+
+	for (UEdGraphPin* Pin : Node->Pins)
+	{
+		if (Pin && Pin->Direction == Direction && IsExecPin(Pin) == bExec)
+		{
+			return Pin;
+		}
+	}
+	return nullptr;
+}
+
+TArray<UEdGraphPin*> FindInputValuePins(UEdGraphNode* Node)
+{
+	TArray<UEdGraphPin*> Result;
+	if (!Node)
+	{
+		return Result;
+	}
+
+	for (UEdGraphPin* Pin : Node->Pins)
+	{
+		if (Pin && Pin->Direction == EGPD_Input && !IsExecPin(Pin))
+		{
+			Result.Add(Pin);
+		}
+	}
+	return Result;
+}
+
+bool IsDslGeneratedNode(const UEdGraphNode* Node)
+{
+	return Node && (Node->NodeComment.StartsWith(TEXT("MCP_DSL_NODE:")) || Node->NodeComment.StartsWith(TEXT("MCP_DSL_EVENT:")));
+}
