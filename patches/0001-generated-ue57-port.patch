+
+	const bool bAdded = Editor->AddMemberVariable(FName(*VariableName), FEdGraphPinType(), DefaultValue);
+	if (!bAdded)
+	{
+		RaiseError(FString::Printf(TEXT("Variable \"%s\" was not added."), *VariableName));
+	}
+	return bAdded;
