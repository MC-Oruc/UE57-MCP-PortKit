+	bool IsSupportedPointField(const FString& AttributeName)
+	{
+		static const TSet<FString> SupportedFields = {
+			TEXT("transform"), TEXT("location"), TEXT("position"), TEXT("rotation"), TEXT("scale"),
+			TEXT("density"), TEXT("boundsmin"), TEXT("boundsmax"), TEXT("color"),
+			TEXT("steepness"), TEXT("seed"), TEXT("metadataentry")
+		};
+
+		return AttributeName.IsEmpty() || SupportedFields.Contains(AttributeName.ToLower());
+	}
+
+	TSharedPtr<FJsonObject> TaggedDataToJson(const FPCGTaggedData& TaggedData, const FString& AttributeName, const int32 StartIndex, const int32 EndIndex)
+	{
+		const UPCGData* Data = TaggedData.Data.Get();
+		if (!Data)
+		{
+			return {};
+		}
+
+		const int32 NumElements = PCGHelpers::GetNumberOfElements(Data);
+		if (StartIndex < 0 || StartIndex > NumElements)
+		{
+			FScriptErrorBridge::RaiseScriptError(FString::Printf(TEXT("Error: StartIndex (%d) out of bounds. Data has %d elements."), StartIndex, NumElements));
+			return {};
+		}
+
+		const int32 EffectiveEnd = EndIndex == -1 ? NumElements : FMath::Min(EndIndex, NumElements);
+		if (EffectiveEnd < StartIndex)
+		{
+			FScriptErrorBridge::RaiseScriptError(FString::Printf(TEXT("Error: EndIndex (%d) is before StartIndex (%d)."), EndIndex, StartIndex));
+			return {};
+		}
+
+		TSharedPtr<FJsonObject> JsonObject = MakeShared<FJsonObject>();
+		JsonObject->SetStringField(TEXT("dataType"), Data->GetClass()->GetName());
+		JsonObject->SetStringField(TEXT("pin"), TaggedData.Pin.ToString());
+		JsonObject->SetNumberField(TEXT("totalElements"), NumElements);
+		JsonObject->SetNumberField(TEXT("startIndex"), StartIndex);
+		JsonObject->SetNumberField(TEXT("endIndex"), EffectiveEnd);
+
+		TArray<TSharedPtr<FJsonValue>> Tags;
+		for (const FString& Tag : TaggedData.Tags)
+		{
+			Tags.Add(MakeShared<FJsonValueString>(Tag));
+		}
+		JsonObject->SetArrayField(TEXT("tags"), Tags);
+
+		const UPCGBasePointData* PointData = Cast<UPCGBasePointData>(Data);
+		if (!PointData)
+		{
+			JsonObject->SetBoolField(TEXT("supportedElementSerialization"), false);
+			return JsonObject;
+		}
+
+		const FString NormalizedAttributeName = AttributeName.TrimStartAndEnd();
+		if (!IsSupportedPointField(NormalizedAttributeName))
+		{
+			FScriptErrorBridge::RaiseScriptError(FString::Printf(
+				TEXT("Error: AttributeName '%s' is not supported by the UE 5.7 PCG data view subset. Supported built-in point fields: Transform, Location, Position, Rotation, Scale, Density, BoundsMin, BoundsMax, Color, Steepness, Seed, MetadataEntry."),
+				*AttributeName));
+			return {};
+		}
+
+		for (int32 Index = StartIndex; Index < EffectiveEnd; ++Index)
+		{
+			JsonObject->SetObjectField(FString::Printf(TEXT("element_%d"), Index), PointDataElementToJson(PointData, Index, NormalizedAttributeName));
+		}
+
+		return JsonObject;
+	}
+
+	AActor* FindLevelActorByLabel(const FString& ActorLabel)
+	{
+		UEditorActorSubsystem* EditorActorSubsystem = GEditor ? GEditor->GetEditorSubsystem<UEditorActorSubsystem>() : nullptr;
+		if (!EditorActorSubsystem)
+		{
+			return nullptr;
+		}
+
+		TArray<AActor*> AllActors = EditorActorSubsystem->GetAllLevelActors();
+		AActor** FoundActor = AllActors.FindByPredicate([&ActorLabel](const AActor* Actor)
+		{
+			return Actor && Actor->GetActorLabel() == ActorLabel;
+		});
+
+		return FoundActor ? *FoundActor : nullptr;
+	}
