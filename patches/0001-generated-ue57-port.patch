+
+FNiagaraVariant GetParameterValueFromStore(const FNiagaraVariableBase& Parameter, const FNiagaraUserRedirectionParameterStore& UserParameterStore)
+{
+	if (Parameter.IsDataInterface())
+	{
+		const int32 Index = UserParameterStore.IndexOf(Parameter);
+		return Index != INDEX_NONE ? FNiagaraVariant(UserParameterStore.GetDataInterfaces()[Index]) : FNiagaraVariant();
+	}
+
+	if (Parameter.IsUObject())
+	{
+		const int32 Index = UserParameterStore.IndexOf(Parameter);
+		return Index != INDEX_NONE ? FNiagaraVariant(UserParameterStore.GetUObjects()[Index]) : FNiagaraVariant();
+	}
+
+	if (Parameter.GetType() == FNiagaraTypeDefinition::GetPositionDef())
+	{
+		const FVector* Value = UserParameterStore.GetPositionParameterValue(Parameter.GetName());
+		return Value != nullptr ? FNiagaraVariant(Value, sizeof(FVector)) : FNiagaraVariant();
+	}
+
+	TArray<uint8> DataValue;
+	DataValue.AddUninitialized(Parameter.GetSizeInBytes());
+	if (UserParameterStore.CopyParameterData(Parameter, DataValue.GetData()))
+	{
+		return FNiagaraVariant(DataValue);
+	}
+
+	return FNiagaraVariant();
+}
+
+void GetUserVariables(UNiagaraSystem* System, TArray<FNiagaraToolset_UserVariableView>& OutVariables)
+{
+	if (System == nullptr)
+	{
+		return;
+	}
+
+	const FNiagaraUserRedirectionParameterStore& UserParameterStore = System->GetExposedParameters();
+	TArray<FNiagaraVariable> UserVariables;
+	UserParameterStore.GetUserParameters(UserVariables);
+
+	OutVariables.Reset(UserVariables.Num());
+	for (FNiagaraVariable UserVariable : UserVariables)
+	{
+		UserParameterStore.RedirectUserVariable(UserVariable);
+
+		FNiagaraToolset_UserVariableView& VariableView = OutVariables.AddDefaulted_GetRef();
+		VariableView.Name = UserVariable.GetName();
+		VariableView.Type = UserVariable.GetType();
+		VariableView.DefaultValue = GetParameterValueFromStore(UserVariable, UserParameterStore);
+
+		if (UNiagaraScriptVariable* ScriptVariable = FNiagaraEditorUtilities::UserParameters::GetScriptVariableForUserParameter(UserVariable, *System))
+		{
+			VariableView.Description = ScriptVariable->Metadata.Description;
+		}
+	}
+}
+
+bool TryGetPinDefaultValueFromVariant(const UEdGraphSchema_Niagara* NiagaraSchema, const FNiagaraVariableBase& Variable, const FNiagaraVariant& Variant, FString& OutDefaultValue)
+{
+	if (NiagaraSchema == nullptr || Variant.IsValid() == false || Variant.GetMode() != ENiagaraVariantMode::Bytes)
+	{
+		return false;
+	}
+
+	FNiagaraVariable ValueVariable(Variable);
+	if (Variant.GetNumBytes() != ValueVariable.GetSizeInBytes())
+	{
+		return false;
+	}
+
+	ValueVariable.SetData(Variant.GetBytes());
+	return NiagaraSchema->TryGetPinDefaultValueFromNiagaraVariable(ValueVariable, OutDefaultValue);
+}
