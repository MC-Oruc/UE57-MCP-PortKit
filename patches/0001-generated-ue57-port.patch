+class BreakTranspilerTest(_TranspilerTest):
+    """Transpiler: (break) triggers ForLoopWithBreak / ForEachLoopWithBreak."""
+
+    def test_break_in_range_loop_creates_for_loop_with_break(self):
+        self._run(
