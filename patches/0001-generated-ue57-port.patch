+FString UPCGToolset::DrawSpline(
+	const FString& ActorLabel,
+	const TArray<FVector>& Points,
+	const FString& ActorTag,
+	const bool bRedraw,
+	const bool bClosedSpline)
+{
+	if (ActorLabel.IsEmpty())
+	{
+		UKismetSystemLibrary::RaiseScriptError("Error: ActorLabel must be provided");
+		return {};
+	}
+
+	if (Points.Num() < 2)
+	{
+		UKismetSystemLibrary::RaiseScriptError("Error: DrawSpline requires at least two points");
+		return {};
+	}
+
+	UWorld* World = GEditor ? GEditor->GetEditorWorldContext(true).World() : nullptr;
+	if (!World)
+	{
+		UKismetSystemLibrary::RaiseScriptError("Error: EditorWorldContext not found");
+		return {};
+	}
+
+	FScopedTransaction Transaction(INVTEXT("DrawSplineToolCall"));
+	AActor* Actor = nullptr;
+	if (bRedraw)
+	{
+		Actor = PCGToolset::FindLevelActorByLabel(ActorLabel);
+		if (!Actor)
+		{
+			Transaction.Cancel();
+			UKismetSystemLibrary::RaiseScriptError(FString::Printf(TEXT("Error: Actor '%s' not found for redraw"), *ActorLabel));
+			return {};
+		}
+
+		Actor->Modify();
+	}
+	else
+	{
+		FActorSpawnParameters ActorSpawnParams;
+		ActorSpawnParams.Name = MakeUniqueObjectName(World, AActor::StaticClass(), FName(*ActorLabel), EUniqueObjectNameOptions::UniversallyUnique);
+		ActorSpawnParams.InitialActorLabel = ActorLabel;
+		Actor = World->SpawnActor<AActor>(Points[0], FRotator::ZeroRotator, ActorSpawnParams);
+		if (!Actor)
+		{
+			Transaction.Cancel();
+			UKismetSystemLibrary::RaiseScriptError("Error: Spawning spline actor failed");
+			return {};
+		}
+
+		Actor->SetActorLabel(ActorLabel);
+	}
+
