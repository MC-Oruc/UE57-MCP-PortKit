-					UToolsetLibrary::SetObjectProperties(ObjB, JsonToString(GoodRoot.ToSharedRef())));
-				TestNotNull(TEXT("Valid call set the property"), ObjB->RefObj.Get());
-				TestFalse(TEXT("Second rejecting call still rejects"),
