+FMcpBlueprintGraphPin UBlueprintTools::AddNodePin(UEdGraphNode* Node)
+{
+	UEdGraph* Graph = GetNodeGraph(Node);
+	if (!Graph)
+	{
+		return {};
+	}
+
+	if (UMcpBlueprintGraphEditorBridge* Editor = GetGraphEditor(Graph))
+	{
+		const int32 PinCountBefore = Node->Pins.Num();
+		if (!Editor->AddNodePin(Node))
+		{
+			RaiseError(TEXT("Node does not support adding a pin."));
+			return {};
+		}
+		for (int32 Index = PinCountBefore; Index < Node->Pins.Num(); ++Index)
+		{
+			if (Node->Pins[Index] && !Node->Pins[Index]->bHidden)
+			{
+				return UMcpBlueprintGraphPinLibrary::FromNativePin(Node->Pins[Index]);
+			}
+		}
+	}
+	return {};
+}
