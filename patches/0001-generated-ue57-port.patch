+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#include "MaterialTools.h"
+
+#include "AssetRegistry/AssetData.h"
+#include "AssetRegistry/AssetRegistryModule.h"
+#include "AssetToolsModule.h"
