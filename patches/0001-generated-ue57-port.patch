+            StringTableTools.set_entry(string_table, 'KeyB', 'Value B')
+            self.assertEqual(StringTableTools.get_entry(string_table, 'KeyA'), 'Value A')
+            self.assertEqual(StringTableTools.get_entry(string_table, 'KeyB'), 'Value B')
