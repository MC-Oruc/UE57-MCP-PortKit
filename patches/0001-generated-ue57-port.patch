+		FScriptArrayHelper ArrayHelper(ArrayProperty, ArrayValue);
+
+		TArray<FDataRegistrySourceSummary> Result;
+		Result.Reserve(ArrayHelper.Num());
+		for (int32 Index = 0; Index < ArrayHelper.Num(); ++Index)
+		{
+			UObject* SourceObject = SourceObjectProperty->GetObjectPropertyValue(ArrayHelper.GetRawPtr(Index));
+			Result.Add(BuildSourceSummary(Cast<UDataRegistrySource>(SourceObject)));
+		}
+		return Result;
+	}
