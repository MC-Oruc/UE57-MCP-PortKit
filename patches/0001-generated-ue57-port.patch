+FEdGraphPinType UBlueprintTools::MakeBasicPinType(const FString& TypeName)
+{
+	const UEdGraphSchema_K2* Schema = GetDefault<UEdGraphSchema_K2>();
+	const FString Normalized = TypeName.ToLower();
+
+	if (Normalized == TEXT("bool") || Normalized == TEXT("boolean"))
+	{
+		return UBlueprintEditorLibrary::GetBasicTypeByName(UEdGraphSchema_K2::PC_Boolean);
+	}
+	if (Normalized == TEXT("int") || Normalized == TEXT("integer"))
+	{
+		return UBlueprintEditorLibrary::GetBasicTypeByName(UEdGraphSchema_K2::PC_Int);
+	}
+	if (Normalized == TEXT("int64"))
+	{
+		return UBlueprintEditorLibrary::GetBasicTypeByName(UEdGraphSchema_K2::PC_Int64);
+	}
+	if (Normalized == TEXT("float") || Normalized == TEXT("double") || Normalized == TEXT("real"))
+	{
+		return UBlueprintEditorLibrary::GetBasicTypeByName(UEdGraphSchema_K2::PC_Real);
+	}
+	if (Normalized == TEXT("string"))
+	{
+		return UBlueprintEditorLibrary::GetBasicTypeByName(UEdGraphSchema_K2::PC_String);
+	}
+	if (Normalized == TEXT("name"))
+	{
+		return UBlueprintEditorLibrary::GetBasicTypeByName(UEdGraphSchema_K2::PC_Name);
+	}
+	if (Normalized == TEXT("text"))
+	{
+		return UBlueprintEditorLibrary::GetBasicTypeByName(UEdGraphSchema_K2::PC_Text);
+	}
+	if (Normalized == TEXT("byte"))
+	{
+		return UBlueprintEditorLibrary::GetBasicTypeByName(UEdGraphSchema_K2::PC_Byte);
+	}
+
+	RaiseError(FString::Printf(TEXT("Unsupported basic pin type \"%s\"."), *TypeName));
+	return UBlueprintEditorLibrary::GetBasicTypeByName(UEdGraphSchema_K2::PC_Boolean);
+}
+
+FBPVariableDescription* UBlueprintTools::FindVariable(UBlueprint* Blueprint, const FString& VariableName)
+{
+	if (!Blueprint)
+	{
+		return nullptr;
+	}
+
+	const FName Name(*VariableName);
+	for (FBPVariableDescription& Variable : Blueprint->NewVariables)
+	{
+		if (Variable.VarName == Name)
+		{
+			return &Variable;
+		}
+	}
+	return nullptr;
+}
+
+FMcpBlueprintGraphPin UBlueprintTools::FindPinByName(UEdGraphNode* Node, const FString& PinName, EEdGraphPinDirection Direction)
+{
+	if (!Node)
+	{
+		return {};
+	}
+
+	for (UEdGraphPin* NativePin : Node->Pins)
+	{
+		if (NativePin && !NativePin->bHidden && NativePin->Direction == Direction && NativePin->PinName.ToString() == PinName)
+		{
+			return UMcpBlueprintGraphPinLibrary::FromNativePin(NativePin);
+		}
+	}
+	return {};
+}
+
+FEditorToolsetBlueprintPinInfo UBlueprintTools::MakePinInfo(const FMcpBlueprintGraphPin& Pin)
+{
+	FEditorToolsetBlueprintPinInfo Result;
+	Result.Pin = Pin;
+	Result.Name = UMcpBlueprintGraphPinLibrary::GetPinName(Pin).ToString();
+	Result.Direction = UMcpBlueprintGraphPinLibrary::GetPinDirection(Pin) == EGPD_Input ? TEXT("Input") : TEXT("Output");
+	Result.Type = UMcpBlueprintGraphPinLibrary::GetPinTypeDisplayString(Pin).ToString();
+	Result.Value = UMcpBlueprintGraphPinLibrary::GetPinValue(Pin);
+	return Result;
+}
+
+FEditorToolsetBlueprintNodeInfo UBlueprintTools::MakeNodeInfo(UEdGraphNode* Node)
+{
+	FEditorToolsetBlueprintNodeInfo Result;
+	Result.Node = Node;
+	if (!Node)
+	{
+		return Result;
+	}
+
+	Result.Title = Node->GetNodeTitle(ENodeTitleType::ListView).ToString();
+	Result.Category = Node->GetNodeTitle(ENodeTitleType::MenuTitle).ToString();
+	Result.Position = FIntPoint(Node->NodePosX, Node->NodePosY);
+	if (const UK2Node* K2Node = Cast<UK2Node>(Node))
+	{
+		for (const FMcpBlueprintGraphPin& Pin : UMcpBlueprintEditorBridgeLibrary::ListInputPins(K2Node))
+		{
+			Result.Inputs.Add(MakePinInfo(Pin));
+		}
+		for (const FMcpBlueprintGraphPin& Pin : UMcpBlueprintEditorBridgeLibrary::ListOutputPins(K2Node))
+		{
+			Result.Outputs.Add(MakePinInfo(Pin));
+		}
+	}
+	return Result;
+}
