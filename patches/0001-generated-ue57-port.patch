@@ -0,0 +1,68 @@
+# Copyright Epic Games, Inc. All Rights Reserved.
+
+from importlib import import_module
+
+import unreal
+
+from toolset_registry.registration import Registration
+
+
+_BLUEPRINT_REQUIRED_ATTRS = (
+    ('McpBlueprintGraphEditorBridge', None),
+    ('McpBlueprintEditorBridgeLibrary', 'list_graphs'),
+    ('McpBlueprintEditorBridgeLibrary', 'list_graph_names'),
+    ('McpBlueprintEditorBridgeLibrary', 'list_member_variable_names'),
+)
+
+
+def _has_unreal_attr(owner_name: str, attr_name: str | None = None) -> bool:
+    owner = getattr(unreal, owner_name, None)
+    if owner is None:
+        return False
+    return attr_name is None or hasattr(owner, attr_name)
+
+
+def _is_toolset_supported(class_name: str) -> bool:
+    if class_name == 'BlueprintTools':
+        return all(_has_unreal_attr(owner, attr) for owner, attr in _BLUEPRINT_REQUIRED_ATTRS)
+    if class_name == 'MaterialTools':
+        return _has_unreal_attr('MaterialEditingLibrary')
+    return True
+
+
+_TOOLSET_SPECS = (
+    ('actor', 'ActorTools'),
+    ('asset', 'AssetTools'),
+    ('data_asset', 'DataAssetTools'),
+    ('data_table', 'DataTableTools'),
+    ('object', 'ObjectTools'),
+    ('primitive', 'PrimitiveTools'),
+    ('scene', 'SceneTools'),
+    ('skeletal_mesh', 'SkeletalMeshTools'),
+    ('static_mesh', 'StaticMeshTools'),
+    ('string_table', 'StringTableTools'),
+    ('texture', 'TextureTools'),
+)
+
+
+def _load_toolset_class(module_name: str, class_name: str):
+    if not _is_toolset_supported(class_name):
+        return None
+
+    module = import_module(f'{__name__}.{module_name}')
+    globals()[module_name] = module
+    return getattr(module, class_name)
+
+
+_TOOLSET_CLASSES = [
+    toolset_class for toolset_class in (
+        _load_toolset_class(module_name, class_name)
+        for module_name, class_name in _TOOLSET_SPECS
+    )
+    if toolset_class is not None
+]
+
+_registration = Registration([
+    toolset_class for toolset_class in _TOOLSET_CLASSES
+    if _is_toolset_supported(toolset_class.__name__)
+])
