+        bounds = SkeletalMeshTools.get_bounds(self.mesh)
+        self.assertIsInstance(bounds, unreal.BoxSphereBounds)
+        self.assertGreater(bounds.sphere_radius, 0)
+
+    # --- Skeleton & Bones ---
+
+    def test_get_skeleton(self):
