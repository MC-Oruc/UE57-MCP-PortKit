+        self.assertIsInstance(skeleton, unreal.Skeleton)
+
+    def test_get_bone_names(self):
+        """Ensures get_bone_names returns a non-empty list containing all bones."""
+        bone_names = SkeletalMeshTools.get_bone_names(self.mesh)
