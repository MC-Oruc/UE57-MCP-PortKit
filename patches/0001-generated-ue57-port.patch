+
+FString UBlueprintTools::ReadGraphDsl(UEdGraph* Graph)
+{
+	if (!Graph)
+	{
+		RaiseError(TEXT("Graph is null."));
+		return TEXT("");
+	}
+
+	TArray<FString> Lines;
+	for (const FEditorToolsetBlueprintNodeInfo& Info : FindNodes(Graph))
+	{
+		if (Info.Node && Info.Node->NodeComment.StartsWith(TEXT("MCP_DSL_EVENT:")))
+		{
+			Lines.Add(FString::Printf(TEXT("(event %s"), *Info.Node->NodeComment.RightChop(14)));
+			continue;
+		}
+		if (Info.Node && Info.Node->NodeComment.StartsWith(TEXT("MCP_DSL_NODE:")))
+		{
+			Lines.Add(FString::Printf(TEXT("  (%s)"), *Info.Node->NodeComment.RightChop(13)));
+			continue;
+		}
+
+		Lines.Add(FString::Printf(TEXT("node \"%s\" at %d %d"), *Info.Title, Info.Position.X, Info.Position.Y));
+		for (const FEditorToolsetBlueprintPinInfo& Pin : Info.Inputs)
+		{
+			if (!Pin.Value.IsEmpty())
+			{
+				Lines.Add(FString::Printf(TEXT("  input \"%s\" = \"%s\""), *Pin.Name, *Pin.Value));
+			}
+		}
+	}
+	return FString::Join(Lines, TEXT("\n"));
+}
+
+void UBlueprintTools::WriteGraphDsl(UEdGraph* Graph, const FString& Code)
+{
+	if (!Graph)
+	{
+		RaiseError(TEXT("Graph is null."));
+		return;
+	}
+
+	UBlueprint* Blueprint = FBlueprintEditorUtils::FindBlueprintForGraph(Graph);
+	if (!Blueprint)
+	{
+		RaiseError(TEXT("Graph is not owned by a Blueprint."));
+		return;
+	}
+
+	TArray<FBlueprintDslForm> Forms;
+	FString ParseError;
+	if (!ParseBlueprintDsl(Code, Forms, ParseError))
+	{
+		RaiseError(ParseError);
+		return;
+	}
+
+	for (const FBlueprintDslForm& EventForm : Forms)
+	{
+		if (EventForm.Head != TEXT("event") || EventForm.Args.IsEmpty())
+		{
+			RaiseError(TEXT("Graph DSL currently supports only top-level (event EventName ...)."));
+			return;
+		}
+		for (const FBlueprintDslForm& NodeForm : EventForm.Children)
+		{
+			if (NodeForm.Head.StartsWith(TEXT(":")) || FindNodeTypes(Graph, NodeForm.Head).Contains(NodeForm.Head) == false)
+			{
+				RaiseError(FString::Printf(TEXT("Node type \"%s\" is not available in this graph."), *NodeForm.Head));
+				return;
+			}
+		}
+	}
+
+	TArray<UEdGraphNode*> NodesToDelete;
+	for (UEdGraphNode* Node : Graph->Nodes)
+	{
+		if (!Node)
+		{
+			continue;
+		}
+
+		bool bHasLinks = false;
+		for (UEdGraphPin* Pin : Node->Pins)
+		{
+			if (Pin && Pin->LinkedTo.Num() > 0)
+			{
+				bHasLinks = true;
+				break;
+			}
+		}
+
+		if (IsDslGeneratedNode(Node) || (!bHasLinks && !Node->IsA<UK2Node_Event>() && !Node->IsA<UK2Node_FunctionEntry>() && !Node->IsA<UK2Node_FunctionResult>()))
+		{
+			NodesToDelete.Add(Node);
+		}
+	}
+	for (UEdGraphNode* Node : NodesToDelete)
+	{
+		DeleteNode(Node);
+	}
+
+	int32 EventIndex = 0;
+	for (const FBlueprintDslForm& EventForm : Forms)
+	{
+		const FString EventToken = EventForm.Args[0];
+		FString EventName = EventToken;
+		if (EventName.StartsWith(TEXT("Custom|")))
+		{
+			EventName.RightChopInline(7);
+		}
+
+		UEdGraphNode* EventNode = AddEvent(Blueprint, EventName, FIntPoint(0, EventIndex * 500));
+		if (!EventNode)
+		{
+			RaiseError(FString::Printf(TEXT("Event \"%s\" was not created."), *EventToken));
+			return;
+		}
+		EventNode->NodeComment = FString::Printf(TEXT("MCP_DSL_EVENT:%s"), *EventToken);
+
+		UEdGraphPin* PreviousExecOut = FindFirstPin(EventNode, EGPD_Output, true);
+		int32 NodeIndex = 0;
+		for (const FBlueprintDslForm& NodeForm : EventForm.Children)
+		{
+			UEdGraphNode* NewNode = CreateNode(Graph, NodeForm.Head, FIntPoint(320 * (NodeIndex + 1), EventIndex * 500));
+			if (!NewNode)
+			{
+				RaiseError(FString::Printf(TEXT("Node \"%s\" was not created."), *NodeForm.Head));
+				return;
+			}
+			NewNode->NodeComment = FString::Printf(TEXT("MCP_DSL_NODE:%s"), *NodeForm.Head);
+
+			const TArray<UEdGraphPin*> InputPins = FindInputValuePins(NewNode);
+			for (int32 ArgIndex = 0; ArgIndex < NodeForm.Args.Num() && ArgIndex < InputPins.Num(); ++ArgIndex)
+			{
+				SetPinValue(UMcpBlueprintGraphPinLibrary::FromNativePin(InputPins[ArgIndex]), NodeForm.Args[ArgIndex]);
+			}
+
+			if (UEdGraphPin* ExecIn = FindFirstPin(NewNode, EGPD_Input, true))
+			{
+				if (PreviousExecOut)
+				{
+					ConnectPins(
+						UMcpBlueprintGraphPinLibrary::FromNativePin(PreviousExecOut),
+						UMcpBlueprintGraphPinLibrary::FromNativePin(ExecIn));
+				}
+			}
+			if (UEdGraphPin* ExecOut = FindFirstPin(NewNode, EGPD_Output, true))
+			{
+				PreviousExecOut = ExecOut;
+			}
+			++NodeIndex;
+		}
+		++EventIndex;
+	}
+
+	CompileBlueprint(Blueprint);
+}
