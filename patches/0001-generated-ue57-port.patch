+bool UBlueprintTools::RetargetNodeClass(UEdGraphNode* Node, UClass* OldClass, UClass* NewClass)
+{
+	if (!Node || !OldClass || !NewClass)
+	{
+		RaiseError(TEXT("Node, OldClass, or NewClass is null."));
+		return false;
+	}
+
+	UEdGraph* Graph = GetNodeGraph(Node);
+	UMcpBlueprintGraphEditorBridge* Editor = Graph ? GetGraphEditor(Graph) : nullptr;
+	if (!Editor)
+	{
+		RaiseError(TEXT("Node has no graph editor."));
+		return false;
+	}
+
+	const bool bRetargeted = Editor->RetargetNodeClass(Node, OldClass, NewClass);
+	if (!bRetargeted)
+	{
+		RaiseError(TEXT("Node class was not retargeted."));
+	}
+	return bRetargeted;
+}
