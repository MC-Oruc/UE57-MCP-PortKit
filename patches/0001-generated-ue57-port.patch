+void UBlueprintTools::ArrangeNodes(const TArray<UEdGraphNode*>& Nodes)
+{
+	constexpr int32 ColumnCount = 6;
+	constexpr int32 SpacingX = 320;
+	constexpr int32 SpacingY = 220;
+
+	int32 VisibleIndex = 0;
+	for (UEdGraphNode* Node : Nodes)
+	{
+		if (!Node)
+		{
+			continue;
+		}
+
+		const FIntPoint Position((VisibleIndex % ColumnCount) * SpacingX, (VisibleIndex / ColumnCount) * SpacingY);
+		SetNodePosition(Node, Position);
+		++VisibleIndex;
+	}
+}
