+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#include "JsonSchema/JsonSchemaGenerator.h"
+
+#include "UObject/EnumProperty.h"
+#include "UObject/PropertyOptional.h"
+#include "UObject/TextProperty.h"
+#include "UObject/UnrealType.h"
+
+namespace
+{
+	void SetType(const TSharedRef<FJsonObject>& Schema, const TCHAR* Type)
+	{
+		Schema->SetStringField(TEXT("type"), Type);
+	}
+
+	void AddEnumValues(const UEnum* Enum, const TSharedRef<FJsonObject>& Schema)
+	{
+		if (!Enum)
+		{
+			return;
+		}
+
+		TArray<TSharedPtr<FJsonValue>> Values;
+		for (int32 Index = 0; Index < Enum->NumEnums(); ++Index)
+		{
+			const FString Name = Enum->GetAuthoredNameStringByIndex(Index);
+			if (!Name.EndsWith(TEXT("_MAX"), ESearchCase::CaseSensitive))
+			{
+				Values.Add(MakeShared<FJsonValueString>(Name));
+			}
+		}
+
+		Schema->SetStringField(TEXT("type"), TEXT("string"));
+		Schema->SetStringField(TEXT("title"), Enum->GetName());
+		Schema->SetArrayField(TEXT("enum"), Values);
+	}
+
+	bool IsRequiredInputParameter(const FProperty* Property)
+	{
+		return Property
+			&& Property->HasAnyPropertyFlags(CPF_Parm)
+			&& !Property->HasAnyPropertyFlags(CPF_ReturnParm);
+	}
+}
+
+TSharedPtr<FJsonObject> FJsonSchemaGenerator::FPropertyToJsonSchemaObject(
+	const FProperty* Property,
+	const FJsonSchemaPropertyFilter& PropertyFilter)
+{
+	TSharedRef<FJsonObject> Schema = MakeShared<FJsonObject>();
+	if (!BuildPropertySchema(Property, PropertyFilter, Schema))
+	{
+		return nullptr;
+	}
+	return Schema;
+}
+
+TSharedPtr<FJsonObject> FJsonSchemaGenerator::UStructToJsonSchemaObject(
+	const UStruct* Struct,
+	const FJsonSchemaPropertyFilter& PropertyFilter)
+{
+	if (!Struct)
+	{
+		return nullptr;
+	}
+
+	TSharedRef<FJsonObject> Schema = MakeShared<FJsonObject>();
+	const bool bFunctionSchema = Struct->IsA<UFunction>();
+
+	if (bFunctionSchema)
+	{
+		const UObject* Owner = Struct->GetOuter();
+		Schema->SetStringField(
+			TEXT("name"),
+			FString::Printf(TEXT("%s.%s"), Owner ? *Owner->GetName() : TEXT("Unknown"), *Struct->GetName()));
+
+		TSharedRef<FJsonObject> InputSchema = MakeShared<FJsonObject>();
+		TSharedRef<FJsonObject> InputProperties = MakeShared<FJsonObject>();
+		TArray<TSharedPtr<FJsonValue>> RequiredInputs;
+
+		TSharedRef<FJsonObject> OutputSchema = MakeShared<FJsonObject>();
+		TSharedRef<FJsonObject> OutputProperties = MakeShared<FJsonObject>();
+		TArray<TSharedPtr<FJsonValue>> RequiredOutputs;
+
+		for (const FProperty* Property : TFieldRange<FProperty>(Struct))
+		{
+			if (!Property->HasAnyPropertyFlags(CPF_Parm) || PropertyFilter.IsPropertyIgnored(Property))
+			{
+				continue;
+			}
+
+			TSharedRef<FJsonObject> PropertySchema = MakeShared<FJsonObject>();
+			if (!BuildPropertySchema(Property, PropertyFilter, PropertySchema))
+			{
+				continue;
+			}
+
+			const FString JsonKey = PropertyFilter.PropertyAuthoredNameToJsonKey(Property->GetAuthoredName());
+			if (Property->HasAnyPropertyFlags(CPF_ReturnParm))
+			{
+				OutputProperties->SetObjectField(JsonKey, PropertySchema);
+				RequiredOutputs.Add(MakeShared<FJsonValueString>(JsonKey));
+			}
+			else
+			{
+				InputProperties->SetObjectField(JsonKey, PropertySchema);
+				if (IsRequiredInputParameter(Property))
+				{
+					RequiredInputs.Add(MakeShared<FJsonValueString>(JsonKey));
+				}
+			}
+		}
+
+		InputSchema->SetStringField(TEXT("type"), TEXT("object"));
+		if (!InputProperties->Values.IsEmpty())
+		{
+			InputSchema->SetObjectField(TEXT("properties"), InputProperties);
+			if (!RequiredInputs.IsEmpty())
+			{
+				InputSchema->SetArrayField(TEXT("required"), RequiredInputs);
+			}
+		}
+		Schema->SetObjectField(TEXT("inputSchema"), InputSchema);
+
+		if (!OutputProperties->Values.IsEmpty())
+		{
+			OutputSchema->SetStringField(TEXT("type"), TEXT("object"));
+			OutputSchema->SetObjectField(TEXT("properties"), OutputProperties);
+			if (!RequiredOutputs.IsEmpty())
+			{
+				OutputSchema->SetArrayField(TEXT("required"), RequiredOutputs);
+			}
+			Schema->SetObjectField(TEXT("outputSchema"), OutputSchema);
+		}
+
+		return Schema;
+	}
+
+	Schema->SetStringField(TEXT("type"), TEXT("object"));
+	Schema->SetStringField(TEXT("title"), Struct->GetName());
+
+	TSharedRef<FJsonObject> Properties = MakeShared<FJsonObject>();
+	TArray<TSharedPtr<FJsonValue>> Required;
+	for (const FProperty* Property : TFieldRange<FProperty>(Struct))
+	{
+		if (PropertyFilter.IsPropertyIgnored(Property))
+		{
+			continue;
+		}
+
+		TSharedRef<FJsonObject> PropertySchema = MakeShared<FJsonObject>();
+		if (!BuildPropertySchema(Property, PropertyFilter, PropertySchema))
+		{
+			continue;
+		}
+
+		const FString JsonKey = PropertyFilter.PropertyAuthoredNameToJsonKey(Property->GetAuthoredName());
+		Properties->SetObjectField(JsonKey, PropertySchema);
+		Required.Add(MakeShared<FJsonValueString>(JsonKey));
+	}
+
+	if (!Properties->Values.IsEmpty())
+	{
+		Schema->SetObjectField(TEXT("properties"), Properties);
+		Schema->SetArrayField(TEXT("required"), Required);
+	}
+
+	return Schema;
+}
+
+bool FJsonSchemaGenerator::BuildPropertySchema(
+	const FProperty* Property,
+	const FJsonSchemaPropertyFilter& PropertyFilter,
+	const TSharedRef<FJsonObject>& OutputSchema)
+{
+	if (!Property)
+	{
+		return false;
+	}
+
+	if (PropertyFilter.CustomCb && PropertyFilter.CustomCb->IsBound()
+		&& PropertyFilter.CustomCb->Execute(Property, FString(), OutputSchema))
+	{
+		return true;
+	}
+
+	if (Property->ArrayDim > 1)
+	{
+		TSharedRef<FJsonObject> ItemSchema = MakeShared<FJsonObject>();
+		SetType(ItemSchema, TEXT("string"));
+		OutputSchema->SetStringField(TEXT("type"), TEXT("array"));
+		OutputSchema->SetObjectField(TEXT("items"), ItemSchema);
+		OutputSchema->SetNumberField(TEXT("minItems"), Property->ArrayDim);
+		OutputSchema->SetNumberField(TEXT("maxItems"), Property->ArrayDim);
+		return true;
+	}
+
+	if (const FOptionalProperty* OptionalProperty = CastField<FOptionalProperty>(Property))
+	{
+		return BuildPropertySchema(OptionalProperty->GetValueProperty(), PropertyFilter, OutputSchema);
+	}
+
+	if (const FStructProperty* StructProperty = CastField<FStructProperty>(Property))
+	{
+		if (TSharedPtr<FJsonObject> StructSchema = UStructToJsonSchemaObject(StructProperty->Struct, PropertyFilter))
+		{
+			FJsonObject::Duplicate(StructSchema, OutputSchema);
+			return true;
+		}
+		return false;
+	}
+
+	if (const FArrayProperty* ArrayProperty = CastField<FArrayProperty>(Property))
+	{
+		TSharedRef<FJsonObject> ItemSchema = MakeShared<FJsonObject>();
+		BuildPropertySchema(ArrayProperty->Inner, PropertyFilter, ItemSchema);
+		SetType(OutputSchema, TEXT("array"));
+		OutputSchema->SetObjectField(TEXT("items"), ItemSchema);
+		return true;
+	}
+
+	if (const FSetProperty* SetProperty = CastField<FSetProperty>(Property))
+	{
+		TSharedRef<FJsonObject> ItemSchema = MakeShared<FJsonObject>();
+		BuildPropertySchema(SetProperty->ElementProp, PropertyFilter, ItemSchema);
+		SetType(OutputSchema, TEXT("array"));
+		OutputSchema->SetObjectField(TEXT("items"), ItemSchema);
+		OutputSchema->SetBoolField(TEXT("uniqueItems"), true);
+		return true;
+	}
+
+	if (const FMapProperty* MapProperty = CastField<FMapProperty>(Property))
+	{
+		TSharedRef<FJsonObject> ValueSchema = MakeShared<FJsonObject>();
+		BuildPropertySchema(MapProperty->ValueProp, PropertyFilter, ValueSchema);
+		SetType(OutputSchema, TEXT("object"));
+		OutputSchema->SetObjectField(TEXT("additionalProperties"), ValueSchema);
+		return true;
+	}
+
+	if (const FEnumProperty* EnumProperty = CastField<FEnumProperty>(Property))
+	{
+		AddEnumValues(EnumProperty->GetEnum(), OutputSchema);
+		return true;
+	}
+
+	if (const FByteProperty* ByteProperty = CastField<FByteProperty>(Property))
+	{
+		if (ByteProperty->Enum)
+		{
+			AddEnumValues(ByteProperty->Enum, OutputSchema);
+			return true;
+		}
+	}
+
+	if (const FNumericProperty* NumericProperty = CastField<FNumericProperty>(Property))
+	{
+		SetType(OutputSchema, NumericProperty->IsInteger() ? TEXT("integer") : TEXT("number"));
+		return true;
+	}
+
+	if (CastField<FBoolProperty>(Property))
+	{
+		SetType(OutputSchema, TEXT("boolean"));
+		return true;
+	}
+
+	if (CastField<FStrProperty>(Property) || CastField<FTextProperty>(Property) || CastField<FNameProperty>(Property))
+	{
+		SetType(OutputSchema, TEXT("string"));
+		return true;
+	}
+
+	if (CastField<FObjectPropertyBase>(Property))
+	{
+		SetType(OutputSchema, TEXT("string"));
+		return true;
+	}
+
+	SetType(OutputSchema, TEXT("string"));
+	return true;
+}
diff --git a/Plugins/ToolsetRegistry/Source/ToolsetRegistry/Private/JsonSchema/JsonSchemaGenerator.h b/Plugins/ToolsetRegistry/Source/ToolsetRegistry/Private/JsonSchema/JsonSchemaGenerator.h
new file mode 100644
index 0000000..1822b63
--- /dev/null
+++ b/Plugins/ToolsetRegistry/Source/ToolsetRegistry/Private/JsonSchema/JsonSchemaGenerator.h
@@ -0,0 +1,39 @@
+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#pragma once
+
+#include "CoreMinimal.h"
+#include "Dom/JsonObject.h"
+#include "JsonSchema/JsonSchemaPropertyFilter.h"
+
+class FJsonSchemaGenerator
+{
+public:
+	static TSharedPtr<FJsonObject> FPropertyToJsonSchemaObject(
+		const FProperty* Property,
+		const FJsonSchemaPropertyFilter& PropertyFilter = FJsonSchemaPropertyFilter());
+
+	static TSharedPtr<FJsonObject> UStructToJsonSchemaObject(
+		const UStruct* Struct,
+		const FJsonSchemaPropertyFilter& PropertyFilter = FJsonSchemaPropertyFilter());
+
+	template<typename InStructType>
+	static TSharedPtr<FJsonObject> UStructToJsonSchemaObject(
+		const FJsonSchemaPropertyFilter& PropertyFilter = FJsonSchemaPropertyFilter())
+	{
+		if constexpr (TModels<CStaticClassProvider, InStructType>::Value)
+		{
+			return UStructToJsonSchemaObject(InStructType::StaticClass(), PropertyFilter);
+		}
+		else
+		{
+			return UStructToJsonSchemaObject(InStructType::StaticStruct(), PropertyFilter);
+		}
+	}
+
+private:
+	static bool BuildPropertySchema(
+		const FProperty* Property,
+		const FJsonSchemaPropertyFilter& PropertyFilter,
+		const TSharedRef<FJsonObject>& OutputSchema);
+};
diff --git a/Plugins/ToolsetRegistry/Source/ToolsetRegistry/Private/JsonSchema/JsonSchemaPropertyFilter.h b/Plugins/ToolsetRegistry/Source/ToolsetRegistry/Private/JsonSchema/JsonSchemaPropertyFilter.h
new file mode 100644
index 0000000..3398327
--- /dev/null
+++ b/Plugins/ToolsetRegistry/Source/ToolsetRegistry/Private/JsonSchema/JsonSchemaPropertyFilter.h
@@ -0,0 +1,30 @@
+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#pragma once
+
+#include "CoreMinimal.h"
+#include "JsonObjectConverter.h"
+
+struct FJsonSchemaPropertyFilter
+{
+	using CustomCallback = TDelegate<bool(const FProperty* Property, const FString& ParameterDefaultString, const TSharedRef<FJsonObject>& OutputSchema)>;
+
+	EPropertyFlags CheckFlags = CPF_None;
+	EPropertyFlags SkipFlags = CPF_None;
+	CustomCallback* CustomCb = nullptr;
+
+	bool IsPropertyIgnored(const FProperty* Property) const
+	{
+		if (!Property || Property->HasAnyPropertyFlags(SkipFlags))
+		{
+			return true;
+		}
+
+		return CheckFlags != CPF_None && !Property->HasAnyPropertyFlags(CheckFlags);
+	}
+
+	FString PropertyAuthoredNameToJsonKey(const FString& PropertyAuthoredName) const
+	{
+		return FJsonObjectConverter::StandardizeCase(PropertyAuthoredName);
+	}
+};
