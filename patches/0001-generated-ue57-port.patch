+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#include "MaterialInstanceTools.h"
+
+#include "AssetToolsModule.h"
+#include "Factories/MaterialInstanceConstantFactoryNew.h"
+#include "MaterialEditingLibrary.h"
+#include "Materials/Material.h"
+#include "Materials/MaterialInstanceConstant.h"
+#include "Modules/ModuleManager.h"
+
+namespace
+{
+	void RaiseMaterialInstanceError(const FString& Message)
+	{
+		FFrame::KismetExecutionMessage(*Message, ELogVerbosity::Error);
+	}
+
+	void AddParameters(
+		TArray<FEditorToolsetMaterialParameter>& Result,
+		const TArray<FName>& Names,
+		EEditorToolsetMaterialParameterType Type)
+	{
+		for (const FName Name : Names)
+		{
+			FEditorToolsetMaterialParameter Parameter;
+			Parameter.Name = Name.ToString();
+			Parameter.Type = Type;
+			Result.Add(Parameter);
+		}
+	}
+
+	template <typename ParameterValueType>
+	bool RemoveParameterValueOverride(TArray<ParameterValueType>& ParameterValues, const FMaterialParameterInfo& ParameterInfo)
+	{
+		const int32 Index = ParameterValues.IndexOfByPredicate(
+			[&ParameterInfo](const ParameterValueType& Parameter)
+			{
+				return Parameter.ParameterInfo == ParameterInfo;
+			});
+
+		if (Index == INDEX_NONE)
+		{
+			return false;
+		}
+
+		ParameterValues.RemoveAt(Index);
+		return true;
+	}
+
+	template <typename StaticParameterType>
+	bool DisableStaticParameterOverride(TArray<StaticParameterType>& Parameters, const FMaterialParameterInfo& ParameterInfo)
+	{
+		for (StaticParameterType& Parameter : Parameters)
+		{
+			if (Parameter.ParameterInfo == ParameterInfo)
+			{
+				Parameter.bOverride = false;
+				return true;
+			}
+		}
+
+		return false;
+	}
+}
+
+UMaterialInstanceConstant* UMaterialInstanceTools::Create(
+	const FString& FolderPath,
+	const FString& AssetName,
+	UMaterialInterface* Parent)
+{
+	if (!Parent)
+	{
+		RaiseMaterialInstanceError(TEXT("Parent material is null."));
+		return nullptr;
+	}
+
+	UMaterialInstanceConstantFactoryNew* Factory = NewObject<UMaterialInstanceConstantFactoryNew>();
+	UObject* Asset = FAssetToolsModule::GetModule().Get().CreateAsset(
+		AssetName,
+		FolderPath,
+		UMaterialInstanceConstant::StaticClass(),
+		Factory);
+
+	UMaterialInstanceConstant* Instance = Cast<UMaterialInstanceConstant>(Asset);
+	if (!Instance)
+	{
+		RaiseMaterialInstanceError(FString::Printf(TEXT("Unable to create MaterialInstanceConstant in %s/%s."), *FolderPath, *AssetName));
+		return nullptr;
+	}
+
+	UMaterialEditingLibrary::SetMaterialInstanceParent(Instance, Parent);
+	UpdateInstance(Instance);
+	return Instance;
+}
+
+TArray<FEditorToolsetMaterialParameter> UMaterialInstanceTools::ListParameters(UMaterialInterface* Material)
+{
+	if (!Material)
+	{
+		RaiseMaterialInstanceError(TEXT("Material is null."));
+		return {};
+	}
+
+	TArray<FEditorToolsetMaterialParameter> Result;
+	TArray<FName> Names;
+
+	UMaterialEditingLibrary::GetScalarParameterNames(Material, Names);
+	AddParameters(Result, Names, EEditorToolsetMaterialParameterType::Scalar);
+
+	Names.Reset();
+	UMaterialEditingLibrary::GetVectorParameterNames(Material, Names);
+	AddParameters(Result, Names, EEditorToolsetMaterialParameterType::Vector);
+
+	Names.Reset();
+	UMaterialEditingLibrary::GetTextureParameterNames(Material, Names);
+	AddParameters(Result, Names, EEditorToolsetMaterialParameterType::Texture);
+
+	Names.Reset();
+	UMaterialEditingLibrary::GetStaticSwitchParameterNames(Material, Names);
+	AddParameters(Result, Names, EEditorToolsetMaterialParameterType::StaticSwitch);
+
+	return Result;
+}
+
+float UMaterialInstanceTools::GetScalarParameter(UMaterialInstanceConstant* Instance, const FString& Name)
+{
+	EnsureInstance(Instance);
+	const FName ParameterName = ToParameterName(Name);
+	EnsureParameter(Instance, ParameterName, EEditorToolsetMaterialParameterType::Scalar);
+	return UMaterialEditingLibrary::GetMaterialInstanceScalarParameterValue(Instance, ParameterName);
+}
+
+void UMaterialInstanceTools::SetScalarParameter(UMaterialInstanceConstant* Instance, const FString& Name, float Value)
+{
+	EnsureInstance(Instance);
+	const FName ParameterName = ToParameterName(Name);
+	EnsureParameter(Instance, ParameterName, EEditorToolsetMaterialParameterType::Scalar);
+	UMaterialEditingLibrary::SetMaterialInstanceScalarParameterValue(Instance, ParameterName, Value);
+	UpdateInstance(Instance);
+}
+
+FLinearColor UMaterialInstanceTools::GetVectorParameter(UMaterialInstanceConstant* Instance, const FString& Name)
+{
+	EnsureInstance(Instance);
+	const FName ParameterName = ToParameterName(Name);
+	EnsureParameter(Instance, ParameterName, EEditorToolsetMaterialParameterType::Vector);
+	return UMaterialEditingLibrary::GetMaterialInstanceVectorParameterValue(Instance, ParameterName);
+}
+
+void UMaterialInstanceTools::SetVectorParameter(UMaterialInstanceConstant* Instance, const FString& Name, FLinearColor Value)
+{
+	EnsureInstance(Instance);
+	const FName ParameterName = ToParameterName(Name);
+	EnsureParameter(Instance, ParameterName, EEditorToolsetMaterialParameterType::Vector);
+	UMaterialEditingLibrary::SetMaterialInstanceVectorParameterValue(Instance, ParameterName, Value);
+	UpdateInstance(Instance);
+}
+
+UTexture* UMaterialInstanceTools::GetTextureParameter(UMaterialInstanceConstant* Instance, const FString& Name)
+{
+	EnsureInstance(Instance);
+	const FName ParameterName = ToParameterName(Name);
+	EnsureParameter(Instance, ParameterName, EEditorToolsetMaterialParameterType::Texture);
+	return UMaterialEditingLibrary::GetMaterialInstanceTextureParameterValue(Instance, ParameterName);
+}
+
+void UMaterialInstanceTools::SetTextureParameter(UMaterialInstanceConstant* Instance, const FString& Name, UTexture* Value)
+{
+	EnsureInstance(Instance);
+	const FName ParameterName = ToParameterName(Name);
+	EnsureParameter(Instance, ParameterName, EEditorToolsetMaterialParameterType::Texture);
+	UMaterialEditingLibrary::SetMaterialInstanceTextureParameterValue(Instance, ParameterName, Value);
+	UpdateInstance(Instance);
+}
+
+bool UMaterialInstanceTools::GetStaticSwitchParameter(UMaterialInstanceConstant* Instance, const FString& Name)
+{
+	EnsureInstance(Instance);
+	const FName ParameterName = ToParameterName(Name);
+	EnsureParameter(Instance, ParameterName, EEditorToolsetMaterialParameterType::StaticSwitch);
+	return UMaterialEditingLibrary::GetMaterialInstanceStaticSwitchParameterValue(Instance, ParameterName);
+}
+
+void UMaterialInstanceTools::SetStaticSwitchParameter(UMaterialInstanceConstant* Instance, const FString& Name, bool Value)
+{
+	EnsureInstance(Instance);
+	const FName ParameterName = ToParameterName(Name);
+	EnsureParameter(Instance, ParameterName, EEditorToolsetMaterialParameterType::StaticSwitch);
+	UMaterialEditingLibrary::SetMaterialInstanceStaticSwitchParameterValue(Instance, ParameterName, Value);
+	UpdateInstance(Instance);
+
+	if (UMaterial* BaseMaterial = Instance->GetBaseMaterial())
+	{
+		UMaterialEditingLibrary::RecompileMaterial(BaseMaterial);
+	}
+}
+
+void UMaterialInstanceTools::SetParameterOverride(UMaterialInstanceConstant* Instance, const FString& Name, bool bOverride)
+{
+	EnsureInstance(Instance);
+
+	if (!Instance)
+	{
+		return;
+	}
+
+	const FName ParameterName = ToParameterName(Name);
+	const FMaterialParameterInfo ParameterInfo(ParameterName);
+	FMaterialParameterMetadata Metadata;
+	EMaterialParameterType ParameterType = EMaterialParameterType::None;
+
+	const EMaterialParameterType SupportedTypes[] =
+	{
+		EMaterialParameterType::Scalar,
+		EMaterialParameterType::Vector,
+		EMaterialParameterType::Texture,
+		EMaterialParameterType::StaticSwitch,
+	};
+
+	for (const EMaterialParameterType SupportedType : SupportedTypes)
+	{
+		if (Instance->GetParameterValue(SupportedType, ParameterInfo, Metadata))
+		{
+			ParameterType = SupportedType;
+			break;
+		}
+	}
+
+	if (ParameterType == EMaterialParameterType::None)
+	{
+		RaiseMaterialInstanceError(FString::Printf(TEXT("Parameter \"%s\" not found in this material instance hierarchy."), *Name));
+		return;
+	}
+
+	if (Metadata.bOverride == bOverride)
+	{
+		return;
+	}
+
+	bool bChanged = false;
+	if (bOverride)
+	{
+		switch (ParameterType)
+		{
+		case EMaterialParameterType::Scalar:
+			Instance->SetScalarParameterValueEditorOnly(ParameterInfo, Metadata.Value.AsScalar());
+			bChanged = true;
+			break;
+		case EMaterialParameterType::Vector:
+			Instance->SetVectorParameterValueEditorOnly(ParameterInfo, Metadata.Value.AsLinearColor());
+			bChanged = true;
+			break;
+		case EMaterialParameterType::Texture:
+			Instance->SetTextureParameterValueEditorOnly(ParameterInfo, Metadata.Value.Texture);
+			bChanged = true;
+			break;
+		case EMaterialParameterType::StaticSwitch:
+			Instance->SetStaticSwitchParameterValueEditorOnly(ParameterInfo, Metadata.Value.AsStaticSwitch());
+			bChanged = true;
+			break;
+		default:
+			break;
+		}
+	}
+	else
+	{
+		switch (ParameterType)
+		{
+		case EMaterialParameterType::Scalar:
+			bChanged = RemoveParameterValueOverride(Instance->ScalarParameterValues, ParameterInfo);
+			break;
+		case EMaterialParameterType::Vector:
+			bChanged = RemoveParameterValueOverride(Instance->VectorParameterValues, ParameterInfo);
+			break;
+		case EMaterialParameterType::Texture:
+			bChanged = RemoveParameterValueOverride(Instance->TextureParameterValues, ParameterInfo);
+			break;
+		case EMaterialParameterType::StaticSwitch:
+			{
+				FStaticParameterSet StaticParameters = Instance->GetStaticParameters();
+				bChanged = DisableStaticParameterOverride(StaticParameters.StaticSwitchParameters, ParameterInfo);
+				if (bChanged)
+				{
+					Instance->UpdateStaticPermutation(StaticParameters);
+				}
+			}
+			break;
+		default:
+			break;
+		}
+	}
+
+	if (!bChanged)
+	{
+		RaiseMaterialInstanceError(FString::Printf(TEXT("Unable to set override state for parameter \"%s\"."), *Name));
+		return;
+	}
+
+	UpdateInstance(Instance);
+
+	if (ParameterType == EMaterialParameterType::StaticSwitch)
+	{
+		if (UMaterial* BaseMaterial = Instance->GetBaseMaterial())
+		{
+			UMaterialEditingLibrary::RecompileMaterial(BaseMaterial);
+		}
+	}
+}
+
+void UMaterialInstanceTools::SetParent(UMaterialInstanceConstant* Instance, UMaterialInterface* Parent)
+{
+	EnsureInstance(Instance);
+	if (!Parent)
+	{
+		RaiseMaterialInstanceError(TEXT("Parent material is null."));
+		return;
+	}
+
+	UMaterialEditingLibrary::SetMaterialInstanceParent(Instance, Parent);
+	UpdateInstance(Instance);
+}
+
+void UMaterialInstanceTools::ClearParameters(UMaterialInstanceConstant* Instance)
+{
+	EnsureInstance(Instance);
+	UMaterialEditingLibrary::ClearAllMaterialInstanceParameters(Instance);
+	UpdateInstance(Instance);
+}
+
+FName UMaterialInstanceTools::ToParameterName(const FString& Name)
+{
+	return FName(*Name);
+}
+
+bool UMaterialInstanceTools::HasParameter(UMaterialInterface* Material, FName Name, EEditorToolsetMaterialParameterType Type)
+{
+	if (!Material)
+	{
+		return false;
+	}
+
+	TArray<FName> Names;
+	switch (Type)
+	{
+	case EEditorToolsetMaterialParameterType::Scalar:
+		UMaterialEditingLibrary::GetScalarParameterNames(Material, Names);
+		break;
+	case EEditorToolsetMaterialParameterType::Vector:
+		UMaterialEditingLibrary::GetVectorParameterNames(Material, Names);
+		break;
+	case EEditorToolsetMaterialParameterType::Texture:
+		UMaterialEditingLibrary::GetTextureParameterNames(Material, Names);
+		break;
+	case EEditorToolsetMaterialParameterType::StaticSwitch:
+		UMaterialEditingLibrary::GetStaticSwitchParameterNames(Material, Names);
+		break;
+	}
+
+	return Names.Contains(Name);
+}
+
+void UMaterialInstanceTools::EnsureInstance(const UMaterialInstanceConstant* Instance)
+{
+	if (!Instance)
+	{
+		RaiseMaterialInstanceError(TEXT("MaterialInstanceConstant is null."));
+	}
+}
+
+void UMaterialInstanceTools::EnsureParameter(UMaterialInterface* Material, FName Name, EEditorToolsetMaterialParameterType Type)
+{
+	if (!HasParameter(Material, Name, Type))
+	{
+		RaiseMaterialInstanceError(FString::Printf(TEXT("Parameter \"%s\" does not exist with the requested type."), *Name.ToString()));
+	}
+}
+
+void UMaterialInstanceTools::UpdateInstance(UMaterialInstanceConstant* Instance)
+{
+	if (!Instance)
+	{
+		return;
+	}
+
+	UMaterialEditingLibrary::UpdateMaterialInstance(Instance);
+	Instance->MarkPackageDirty();
+}
