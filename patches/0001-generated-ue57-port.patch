+	if (!SplineComponent)
+	{
+		SplineComponent = NewObject<USplineComponent>(Actor, USplineComponent::StaticClass(), NAME_None, RF_Transactional);
+		if (!SplineComponent)
+		{
+			Transaction.Cancel();
+			UKismetSystemLibrary::RaiseScriptError("Error: Creating spline component failed");
+			return {};
+		}
+
+		Actor->AddInstanceComponent(SplineComponent);
+		if (!Actor->GetRootComponent())
+		{
+			Actor->SetRootComponent(SplineComponent);
+		}
+
+		SplineComponent->RegisterComponent();
+	}
+
+	SplineComponent->Modify();
+	SplineComponent->SetSplinePoints(Points, ESplineCoordinateSpace::World, false);
+	SplineComponent->SetClosedLoop(bClosedSpline, false);
+	SplineComponent->UpdateSpline();
+
+	Actor->MarkPackageDirty();
+	return Actor->GetPathName();
+}
