+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#include "CurveTableTools.h"
+
+#include "AssetToolsModule.h"
+#include "AutomatedAssetImportData.h"
+#include "Curves/SimpleCurve.h"
+#include "Engine/CurveTable.h"
+#include "Factories/CSVImportFactory.h"
+#include "Factories/CurveTableFactory.h"
+#include "Misc/Paths.h"
+#include "Modules/ModuleManager.h"
+
+namespace
+{
+	const FString CurveTableContext(TEXT("CurveTableTools"));
+
+	void RaiseCurveTableError(const FString& Message)
+	{
+		FFrame::KismetExecutionMessage(*Message, ELogVerbosity::Error);
+	}
+
+	FEditorToolsetSimpleCurveKey ToToolKey(const FSimpleCurveKey& Key)
+	{
+		FEditorToolsetSimpleCurveKey Result;
+		Result.Time = Key.Time;
+		Result.Value = Key.Value;
+		return Result;
+	}
+}
+
+TArray<UObject*> UCurveTableTools::ImportFile(
+	const FString& FolderPath,
+	const FString& AssetName,
+	const FString& SourceFile,
+	ERichCurveInterpMode InterpMode)
+{
+	if (InterpMode != RCIM_Linear && InterpMode != RCIM_Constant)
+	{
+		RaiseCurveTableError(TEXT("CurveTableTools only supports linear or constant interpolation for simple curve tables."));
+		return {};
+	}
+
+	UCSVImportFactory* Factory = NewObject<UCSVImportFactory>();
+	Factory->AutomatedImportSettings.ImportType = ECSVImportType::ECSV_CurveTable;
+	Factory->AutomatedImportSettings.ImportCurveInterpMode = InterpMode;
+	Factory->AutomatedImportSettings.bForceAutomatedImport = true;
+
+	UAutomatedAssetImportData* ImportData = NewObject<UAutomatedAssetImportData>();
+	ImportData->Filenames = { SourceFile };
+	ImportData->DestinationPath = FolderPath;
+	ImportData->Factory = Factory;
+	ImportData->bReplaceExisting = true;
+
+	FAssetToolsModule& AssetToolsModule = FAssetToolsModule::GetModule();
+	TArray<UObject*> ImportedAssets = AssetToolsModule.Get().ImportAssetsAutomated(ImportData);
+	if (ImportedAssets.Num() == 1 && !AssetName.IsEmpty() && ImportedAssets[0] && ImportedAssets[0]->GetName() != AssetName)
+	{
+		FString PackagePath;
+		FString CurrentAssetName;
+		ImportedAssets[0]->GetOutermost()->GetName().Split(TEXT("/"), &PackagePath, &CurrentAssetName, ESearchCase::CaseSensitive, ESearchDir::FromEnd);
+		AssetToolsModule.Get().RenameAssets({ FAssetRenameData(ImportedAssets[0], FolderPath, AssetName) });
+	}
+
+	return ImportedAssets;
+}
+
+UCurveTable* UCurveTableTools::Create(const FString& FolderPath, const FString& AssetName)
+{
+	UCurveTableFactory* Factory = NewObject<UCurveTableFactory>();
+	UObject* Asset = FAssetToolsModule::GetModule().Get().CreateAsset(
+		AssetName,
+		FolderPath,
+		UCurveTable::StaticClass(),
+		Factory);
+
+	UCurveTable* CurveTable = Cast<UCurveTable>(Asset);
+	if (!CurveTable)
+	{
+		RaiseCurveTableError(FString::Printf(TEXT("Unable to create CurveTable in %s/%s."), *FolderPath, *AssetName));
+	}
+	return CurveTable;
+}
+
+TArray<FString> UCurveTableTools::ListRows(const UCurveTable* CurveTable)
+{
+	EnsureTable(CurveTable);
+
+	TArray<FString> Rows;
+	for (const TPair<FName, FRealCurve*>& Row : CurveTable->GetRowMap())
+	{
+		Rows.Add(Row.Key.ToString());
+	}
+	Rows.Sort();
+	return Rows;
+}
+
+void UCurveTableTools::AddRow(UCurveTable* CurveTable, const FString& RowName, float DefaultValue)
+{
+	EnsureTable(CurveTable);
+	EnsureSimpleCurveTable(CurveTable);
+
+	const FName Name = ToRowName(RowName);
+	EnsureRowDoesNotExist(CurveTable, Name);
+
+	FSimpleCurve& Curve = CurveTable->AddSimpleCurve(Name);
+	Curve.SetDefaultValue(DefaultValue);
+	MarkChanged(CurveTable);
+	EnsureRowExists(CurveTable, Name);
+}
+
+void UCurveTableTools::RemoveRow(UCurveTable* CurveTable, const FString& RowName)
+{
+	EnsureTable(CurveTable);
+	const FName Name = ToRowName(RowName);
+	EnsureRowExists(CurveTable, Name);
+	CurveTable->RemoveRow(Name);
+	MarkChanged(CurveTable);
+}
+
+void UCurveTableTools::RenameRow(UCurveTable* CurveTable, const FString& RowName, const FString& NewRowName)
+{
+	EnsureTable(CurveTable);
+	FName Name = ToRowName(RowName);
+	FName NewName = ToRowName(NewRowName);
+	EnsureRowExists(CurveTable, Name);
+	EnsureRowDoesNotExist(CurveTable, NewName);
+	CurveTable->RenameRow(Name, NewName);
+	MarkChanged(CurveTable);
+}
+
+bool UCurveTableTools::AddKey(UCurveTable* CurveTable, const FString& RowName, const FEditorToolsetSimpleCurveKey& Key)
+{
+	EnsureTable(CurveTable);
+	EnsureSimpleCurveTable(CurveTable);
+	FSimpleCurve* Curve = CurveTable->FindSimpleCurve(ToRowName(RowName), CurveTableContext, false);
+	if (!Curve)
+	{
+		RaiseCurveTableError(FString::Printf(TEXT("Row \"%s\" does not exist in the curve table."), *RowName));
+		return false;
+	}
+
+	Curve->AddKey(Key.Time, Key.Value);
+	MarkChanged(CurveTable);
+	return true;
+}
+
+bool UCurveTableTools::SetKeys(UCurveTable* CurveTable, const FString& RowName, const TArray<FEditorToolsetSimpleCurveKey>& Keys)
+{
+	EnsureTable(CurveTable);
+	EnsureSimpleCurveTable(CurveTable);
+
+	const FName Name = ToRowName(RowName);
+	EnsureRowExists(CurveTable, Name);
+	CurveTable->RemoveRow(Name);
+	FSimpleCurve& Curve = CurveTable->AddSimpleCurve(Name);
+
+	TArray<FSimpleCurveKey> NativeKeys;
+	NativeKeys.Reserve(Keys.Num());
+	for (const FEditorToolsetSimpleCurveKey& Key : Keys)
+	{
+		NativeKeys.Emplace(Key.Time, Key.Value);
+	}
+	NativeKeys.Sort([](const FSimpleCurveKey& A, const FSimpleCurveKey& B)
+	{
+		return A.Time < B.Time;
+	});
+	Curve.SetKeys(NativeKeys);
+	MarkChanged(CurveTable);
+	return true;
+}
+
+TArray<FEditorToolsetSimpleCurveKey> UCurveTableTools::GetKeys(UCurveTable* CurveTable, const FString& RowName)
+{
+	EnsureTable(CurveTable);
+	EnsureSimpleCurveTable(CurveTable);
+	FSimpleCurve* Curve = CurveTable->FindSimpleCurve(ToRowName(RowName), CurveTableContext, false);
+	if (!Curve)
+	{
+		RaiseCurveTableError(FString::Printf(TEXT("Row \"%s\" does not exist in the curve table."), *RowName));
+		return {};
+	}
+
+	TArray<FEditorToolsetSimpleCurveKey> Result;
+	for (const FSimpleCurveKey& Key : Curve->GetConstRefOfKeys())
+	{
+		Result.Add(ToToolKey(Key));
+	}
+	return Result;
+}
+
+FName UCurveTableTools::ToRowName(const FString& RowName)
+{
+	return FName(*RowName);
+}
+
+void UCurveTableTools::EnsureTable(const UCurveTable* CurveTable)
+{
+	if (!CurveTable)
+	{
+		RaiseCurveTableError(TEXT("CurveTable is null."));
+	}
+}
+
+void UCurveTableTools::EnsureSimpleCurveTable(const UCurveTable* CurveTable)
+{
+	if (CurveTable && CurveTable->GetCurveTableMode() == ECurveTableMode::RichCurves)
+	{
+		RaiseCurveTableError(TEXT("Rich curve tables are not supported by CurveTableTools."));
+	}
+}
+
+void UCurveTableTools::EnsureRowExists(const UCurveTable* CurveTable, FName RowName)
+{
+	if (!CurveTable || !CurveTable->FindCurve(RowName, CurveTableContext, false))
+	{
+		RaiseCurveTableError(FString::Printf(TEXT("Row \"%s\" does not exist in the curve table."), *RowName.ToString()));
+	}
+}
+
+void UCurveTableTools::EnsureRowDoesNotExist(const UCurveTable* CurveTable, FName RowName)
+{
+	if (CurveTable && CurveTable->FindCurve(RowName, CurveTableContext, false))
+	{
+		RaiseCurveTableError(FString::Printf(TEXT("Row \"%s\" already exists in the curve table."), *RowName.ToString()));
+	}
+}
+
+void UCurveTableTools::MarkChanged(UCurveTable* CurveTable)
+{
+	if (!CurveTable)
+	{
+		return;
+	}
+
+	CurveTable->Modify();
+	CurveTable->OnCurveTableChanged().Broadcast();
+	CurveTable->MarkPackageDirty();
+}
