+bool UEditorAppToolset::ExecuteConsoleCommand(const FString& Command)
+{
+	if (!GEditor)
+	{
+		RaiseEditorToolsetScriptError(TEXT("Editor not found."));
+		return false;
+	}
+
+	if (Command.TrimStartAndEnd().IsEmpty())
+	{
+		RaiseEditorToolsetScriptError(TEXT("Command cannot be empty."));
+		return false;
+	}
+
+	UWorld* World = nullptr;
+	if (GEditor->PlayWorld)
+	{
+		World = GEditor->PlayWorld.Get();
+	}
+	else
+	{
+		World = GEditor->GetEditorWorldContext().World();
+	}
+	return GEditor->Exec(World, *Command);
+}
