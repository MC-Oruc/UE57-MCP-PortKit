+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#include "StateTreeToolset/StateTreeToolsetBridge.h"
+
+#include "StateTree.h"
+
+UStateTreeEditorData* UStateTreeToolsetBridge::GetEditorData(UStateTree* StateTree)
+{
+	if (!StateTree)
+	{
+		return nullptr;
+	}
+
+#if WITH_EDITORONLY_DATA
+	return Cast<UStateTreeEditorData>(StateTree->EditorData);
+#else
+	return nullptr;
+#endif
+}
+
+TArray<UStateTreeState*> UStateTreeToolsetBridge::GetRootStates(UStateTree* StateTree)
+{
+	TArray<UStateTreeState*> Result;
+	const UStateTreeEditorData* EditorData = GetEditorData(StateTree);
+	if (!EditorData)
+	{
+		return Result;
+	}
+
+	Result.Reserve(EditorData->SubTrees.Num());
+	for (UStateTreeState* State : EditorData->SubTrees)
+	{
+		if (State)
+		{
+			Result.Add(State);
+		}
+	}
+	return Result;
+}
+
+TArray<UStateTreeState*> UStateTreeToolsetBridge::GetChildren(UStateTreeState* State)
+{
+	TArray<UStateTreeState*> Result;
+	if (!State)
+	{
+		return Result;
+	}
+
+	Result.Reserve(State->Children.Num());
+	for (UStateTreeState* Child : State->Children)
+	{
+		if (Child)
+		{
+			Result.Add(Child);
+		}
+	}
+	return Result;
+}
