+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#pragma once
+
+#include "Logging/LogMacros.h"
+#include "UObject/Script.h"
+
+#ifndef UE_LOGF
+#define UE_LOGF(CategoryName, Verbosity, Format, ...) UE_LOG(CategoryName, Verbosity, TEXT(Format), ##__VA_ARGS__)
+#endif
+
+#ifndef UE_CLOGF
+#define UE_CLOGF(Condition, CategoryName, Verbosity, Format, ...) UE_CLOG(Condition, CategoryName, Verbosity, TEXT(Format), ##__VA_ARGS__)
+#endif
+
+inline void RaiseEditorToolsetScriptError(const FString& ErrorMessage)
+{
+#if !(UE_BUILD_TEST || UE_BUILD_SHIPPING)
+	FFrame::KismetExecutionMessage(*ErrorMessage, ELogVerbosity::Error);
+#else
+	UE_LOG(LogTemp, Error, TEXT("%s"), *ErrorMessage);
+#endif
+}
